<?xml version="1.0" encoding="utf-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:adonis="http://www.boc-group.com"
             xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definition__c7e3a1b2-d4f5-4890-bcde-fa2345678901"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd"
             targetNamespace="http://www.boc-group.com">

  <!-- =====================================================
       COLLABORATION - Wohnsitz ummelden
       3-Pool-KOI-Kollaboration: Kunde, Organisation, IT
       ===================================================== -->
  <collaboration id="Collaboration_wohnsitz_ummelden_01"
                 name="Wohnsitz ummelden"
                 isClosed="false">

    <participant processRef="process_kunde_wu01"
                 name="Kunde"
                 id="_kunde_participant_wu01"/>
    <participant processRef="process_org_wu01"
                 name="Organisation"
                 id="_org_participant_wu01"/>
    <participant processRef="process_it_wu01"
                 name="IT"
                 id="_it_participant_wu01"/>

    <!-- Message Flows -->
    <!-- Kunde → Organisation: Ummeldungsantrag einreichen -->
    <messageFlow id="_msgflow_k_o_wu01"
                 name="Ummeldungsantrag"
                 sourceRef="_kunde_task2_wu01"
                 targetRef="_org_start_wu01"/>

    <!-- Organisation → IT: Geprüfte Ummeldedaten übermitteln -->
    <messageFlow id="_msgflow_o_it_wu01"
                 name="Geprüfte Ummeldedaten"
                 sourceRef="_org_task3_wu01"
                 targetRef="_it_start_wu01"/>

    <!-- IT → Organisation: Ummeldebestätigung übermitteln -->
    <messageFlow id="_msgflow_it_o_wu01"
                 name="Ummeldebestätigung"
                 sourceRef="_it_task3_wu01"
                 targetRef="_org_task4_wu01"/>

    <!-- Organisation → Kunde: Ummeldebestätigung bereitstellen -->
    <messageFlow id="_msgflow_o_k_wu01"
                 name="Ummeldebestätigung"
                 sourceRef="_org_task4_wu01"
                 targetRef="_kunde_task3_wu01"/>

  </collaboration>

  <!-- =====================================================
       PROZESS: Kunde
       ===================================================== -->
  <process name="Kunde"
           id="process_kunde_wu01"
           isExecutable="false"
           isClosed="false"
           processType="None">

    <laneSet id="laneSet_kunde_wu01">
      <lane name="Antragsteller" id="_kunde_lane_wu01">
        <flowNodeRef>_kunde_start_wu01</flowNodeRef>
        <flowNodeRef>_kunde_task1_wu01</flowNodeRef>
        <flowNodeRef>_kunde_task2_wu01</flowNodeRef>
        <flowNodeRef>_kunde_task3_wu01</flowNodeRef>
        <flowNodeRef>_kunde_end_wu01</flowNodeRef>
      </lane>
    </laneSet>

    <!-- Start Event -->
    <startEvent name="Wohnsitz gewechselt" id="_kunde_start_wu01">
      <outgoing>_kunde_flow1_wu01</outgoing>
    </startEvent>

    <!-- Task 1: Ummeldung vorbereiten -->
    <task name="Ummeldung vorbereiten" id="_kunde_task1_wu01" isForCompensation="false">
      <incoming>_kunde_flow1_wu01</incoming>
      <outgoing>_kunde_flow2_wu01</outgoing>
    </task>

    <!-- Task 2: Ummeldung einreichen -->
    <task name="Ummeldung einreichen" id="_kunde_task2_wu01" isForCompensation="false">
      <incoming>_kunde_flow2_wu01</incoming>
      <outgoing>_kunde_flow3_wu01</outgoing>
    </task>

    <!-- Task 3: Bestätigung empfangen -->
    <task name="Bestätigung empfangen" id="_kunde_task3_wu01" isForCompensation="false">
      <incoming>_kunde_flow3_wu01</incoming>
      <outgoing>_kunde_flow4_wu01</outgoing>
    </task>

    <!-- End Event -->
    <endEvent name="Wohnsitz umgemeldet" id="_kunde_end_wu01">
      <incoming>_kunde_flow4_wu01</incoming>
    </endEvent>

    <!-- Sequence Flows -->
    <sequenceFlow sourceRef="_kunde_start_wu01"  targetRef="_kunde_task1_wu01" id="_kunde_flow1_wu01"/>
    <sequenceFlow sourceRef="_kunde_task1_wu01"  targetRef="_kunde_task2_wu01" id="_kunde_flow2_wu01"/>
    <sequenceFlow sourceRef="_kunde_task2_wu01"  targetRef="_kunde_task3_wu01" id="_kunde_flow3_wu01"/>
    <sequenceFlow sourceRef="_kunde_task3_wu01"  targetRef="_kunde_end_wu01"   id="_kunde_flow4_wu01"/>

  </process>

  <!-- =====================================================
       PROZESS: Organisation
       ===================================================== -->
  <process name="Organisation"
           id="process_org_wu01"
           isExecutable="false"
           isClosed="false"
           processType="None">

    <laneSet id="laneSet_org_wu01">
      <lane name="Meldebehörde" id="_org_lane_wu01">
        <flowNodeRef>_org_start_wu01</flowNodeRef>
        <flowNodeRef>_org_task1_wu01</flowNodeRef>
        <flowNodeRef>_org_task2_wu01</flowNodeRef>
        <flowNodeRef>_org_task3_wu01</flowNodeRef>
        <flowNodeRef>_org_task4_wu01</flowNodeRef>
        <flowNodeRef>_org_end_wu01</flowNodeRef>
      </lane>
    </laneSet>

    <!-- Start Event (Message Start: Ummeldungsantrag eingegangen) -->
    <startEvent name="Ummeldungsantrag eingegangen" id="_org_start_wu01">
      <outgoing>_org_flow1_wu01</outgoing>
      <messageEventDefinition id="msgEvtDef_org_start_wu01"/>
    </startEvent>

    <!-- Task 1: Unterlagen sichten -->
    <task name="Unterlagen sichten" id="_org_task1_wu01" isForCompensation="false">
      <incoming>_org_flow1_wu01</incoming>
      <outgoing>_org_flow2_wu01</outgoing>
    </task>

    <!-- Task 2: Zuständigkeit prüfen -->
    <task name="Zuständigkeit prüfen" id="_org_task2_wu01" isForCompensation="false">
      <incoming>_org_flow2_wu01</incoming>
      <outgoing>_org_flow3_wu01</outgoing>
    </task>

    <!-- Task 3: Ummeldung freigeben -->
    <task name="Ummeldung freigeben" id="_org_task3_wu01" isForCompensation="false">
      <incoming>_org_flow3_wu01</incoming>
      <outgoing>_org_flow4_wu01</outgoing>
    </task>

    <!-- Task 4: Bestätigung bereitstellen -->
    <task name="Bestätigung bereitstellen" id="_org_task4_wu01" isForCompensation="false">
      <incoming>_org_flow4_wu01</incoming>
      <outgoing>_org_flow5_wu01</outgoing>
    </task>

    <!-- End Event -->
    <endEvent name="Ummeldung bearbeitet" id="_org_end_wu01">
      <incoming>_org_flow5_wu01</incoming>
    </endEvent>

    <!-- Sequence Flows -->
    <sequenceFlow sourceRef="_org_start_wu01"  targetRef="_org_task1_wu01" id="_org_flow1_wu01"/>
    <sequenceFlow sourceRef="_org_task1_wu01"  targetRef="_org_task2_wu01" id="_org_flow2_wu01"/>
    <sequenceFlow sourceRef="_org_task2_wu01"  targetRef="_org_task3_wu01" id="_org_flow3_wu01"/>
    <sequenceFlow sourceRef="_org_task3_wu01"  targetRef="_org_task4_wu01" id="_org_flow4_wu01"/>
    <sequenceFlow sourceRef="_org_task4_wu01"  targetRef="_org_end_wu01"   id="_org_flow5_wu01"/>

  </process>

  <!-- =====================================================
       PROZESS: IT
       ===================================================== -->
  <process name="IT"
           id="process_it_wu01"
           isExecutable="false"
           isClosed="false"
           processType="None">

    <laneSet id="laneSet_it_wu01">
      <lane name="IT-Fachverfahren (Melderegister)" id="_it_lane_wu01">
        <flowNodeRef>_it_start_wu01</flowNodeRef>
        <flowNodeRef>_it_task1_wu01</flowNodeRef>
        <flowNodeRef>_it_task2_wu01</flowNodeRef>
        <flowNodeRef>_it_task3_wu01</flowNodeRef>
        <flowNodeRef>_it_end_wu01</flowNodeRef>
      </lane>
    </laneSet>

    <!-- Start Event (Message Start: Ummeldedaten eingegangen) -->
    <startEvent name="Ummeldedaten eingegangen" id="_it_start_wu01">
      <outgoing>_it_flow1_wu01</outgoing>
      <messageEventDefinition id="msgEvtDef_it_start_wu01"/>
    </startEvent>

    <!-- Task 1: Meldedaten abrufen -->
    <task name="Meldedaten abrufen" id="_it_task1_wu01" isForCompensation="false">
      <incoming>_it_flow1_wu01</incoming>
      <outgoing>_it_flow2_wu01</outgoing>
    </task>

    <!-- Task 2: Adressdaten aktualisieren -->
    <task name="Adressdaten aktualisieren" id="_it_task2_wu01" isForCompensation="false">
      <incoming>_it_flow2_wu01</incoming>
      <outgoing>_it_flow3_wu01</outgoing>
    </task>

    <!-- Task 3: Ummeldebestätigung erzeugen -->
    <task name="Ummeldebestätigung erzeugen" id="_it_task3_wu01" isForCompensation="false">
      <incoming>_it_flow3_wu01</incoming>
      <outgoing>_it_flow4_wu01</outgoing>
    </task>

    <!-- End Event -->
    <endEvent name="Meldedaten aktualisiert" id="_it_end_wu01">
      <incoming>_it_flow4_wu01</incoming>
    </endEvent>

    <!-- Sequence Flows -->
    <sequenceFlow sourceRef="_it_start_wu01"  targetRef="_it_task1_wu01" id="_it_flow1_wu01"/>
    <sequenceFlow sourceRef="_it_task1_wu01"  targetRef="_it_task2_wu01" id="_it_flow2_wu01"/>
    <sequenceFlow sourceRef="_it_task2_wu01"  targetRef="_it_task3_wu01" id="_it_flow3_wu01"/>
    <sequenceFlow sourceRef="_it_task3_wu01"  targetRef="_it_end_wu01"   id="_it_flow4_wu01"/>

  </process>

  <!-- =====================================================
       BPMN-DI: Diagramm-Visualisierung
       3-Pool-Layout (KOI):
         Kunde:        y=0,    Höhe=380
         Organisation: y=390,  Höhe=380
         IT:           y=780,  Höhe=380

       Task-Dimensionen: 151 x 76 px
       Event-Dimensionen: 36 x 36 px
       Horizontaler Abstand zwischen Elementen: ~70px

       Kunde (3 Tasks):
         Start:   x=120, y=172
         Task1:   x=220, y=152
         Task2:   x=441, y=152
         Task3:   x=662, y=152
         End:     x=883, y=172

       Organisation (4 Tasks):
         Start:   x=120, y=562
         Task1:   x=220, y=542
         Task2:   x=441, y=542
         Task3:   x=662, y=542
         Task4:   x=883, y=542
         End:     x=1104,y=562

       IT (3 Tasks):
         Start:   x=120, y=952
         Task1:   x=220, y=932
         Task2:   x=441, y=932
         Task3:   x=662, y=932
         End:     x=883, y=952
       ===================================================== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_wu01">
    <bpmndi:BPMNPlane bpmnElement="Collaboration_wohnsitz_ummelden_01">

      <!-- ===== POOL: Kunde ===== -->
      <bpmndi:BPMNShape bpmnElement="_kunde_participant_wu01" isHorizontal="true">
        <omgdc:Bounds x="10" y="0" width="1830" height="380"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="_kunde_lane_wu01" isHorizontal="true">
        <omgdc:Bounds x="40" y="0" width="1800" height="380"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: Start Event -->
      <bpmndi:BPMNShape bpmnElement="_kunde_start_wu01">
        <omgdc:Bounds x="120" y="172" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: Task 1 - Ummeldung vorbereiten -->
      <bpmndi:BPMNShape bpmnElement="_kunde_task1_wu01">
        <omgdc:Bounds x="220" y="152" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: Task 2 - Ummeldung einreichen -->
      <bpmndi:BPMNShape bpmnElement="_kunde_task2_wu01">
        <omgdc:Bounds x="441" y="152" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: Task 3 - Bestätigung empfangen -->
      <bpmndi:BPMNShape bpmnElement="_kunde_task3_wu01">
        <omgdc:Bounds x="662" y="152" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: End Event -->
      <bpmndi:BPMNShape bpmnElement="_kunde_end_wu01">
        <omgdc:Bounds x="883" y="172" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: Sequence Flows -->
      <bpmndi:BPMNEdge bpmnElement="_kunde_flow1_wu01">
        <omgdi:waypoint x="156" y="190"/>
        <omgdi:waypoint x="220" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_kunde_flow2_wu01">
        <omgdi:waypoint x="371" y="190"/>
        <omgdi:waypoint x="441" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_kunde_flow3_wu01">
        <omgdi:waypoint x="592" y="190"/>
        <omgdi:waypoint x="662" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_kunde_flow4_wu01">
        <omgdi:waypoint x="813" y="190"/>
        <omgdi:waypoint x="883" y="190"/>
      </bpmndi:BPMNEdge>

      <!-- ===== POOL: Organisation ===== -->
      <bpmndi:BPMNShape bpmnElement="_org_participant_wu01" isHorizontal="true">
        <omgdc:Bounds x="10" y="390" width="1830" height="380"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="_org_lane_wu01" isHorizontal="true">
        <omgdc:Bounds x="40" y="390" width="1800" height="380"/>
      </bpmndi:BPMNShape>

      <!-- Organisation: Start Event (Message) -->
      <bpmndi:BPMNShape bpmnElement="_org_start_wu01">
        <omgdc:Bounds x="120" y="562" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Organisation: Task 1 - Unterlagen sichten -->
      <bpmndi:BPMNShape bpmnElement="_org_task1_wu01">
        <omgdc:Bounds x="220" y="542" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Organisation: Task 2 - Zuständigkeit prüfen -->
      <bpmndi:BPMNShape bpmnElement="_org_task2_wu01">
        <omgdc:Bounds x="441" y="542" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Organisation: Task 3 - Ummeldung freigeben -->
      <bpmndi:BPMNShape bpmnElement="_org_task3_wu01">
        <omgdc:Bounds x="662" y="542" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Organisation: Task 4 - Bestätigung bereitstellen -->
      <bpmndi:BPMNShape bpmnElement="_org_task4_wu01">
        <omgdc:Bounds x="883" y="542" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Organisation: End Event -->
      <bpmndi:BPMNShape bpmnElement="_org_end_wu01">
        <omgdc:Bounds x="1104" y="562" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Organisation: Sequence Flows -->
      <bpmndi:BPMNEdge bpmnElement="_org_flow1_wu01">
        <omgdi:waypoint x="156" y="580"/>
        <omgdi:waypoint x="220" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_org_flow2_wu01">
        <omgdi:waypoint x="371" y="580"/>
        <omgdi:waypoint x="441" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_org_flow3_wu01">
        <omgdi:waypoint x="592" y="580"/>
        <omgdi:waypoint x="662" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_org_flow4_wu01">
        <omgdi:waypoint x="813" y="580"/>
        <omgdi:waypoint x="883" y="580"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_org_flow5_wu01">
        <omgdi:waypoint x="1034" y="580"/>
        <omgdi:waypoint x="1104" y="580"/>
      </bpmndi:BPMNEdge>

      <!-- ===== POOL: IT ===== -->
      <bpmndi:BPMNShape bpmnElement="_it_participant_wu01" isHorizontal="true">
        <omgdc:Bounds x="10" y="780" width="1830" height="380"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="_it_lane_wu01" isHorizontal="true">
        <omgdc:Bounds x="40" y="780" width="1800" height="380"/>
      </bpmndi:BPMNShape>

      <!-- IT: Start Event (Message) -->
      <bpmndi:BPMNShape bpmnElement="_it_start_wu01">
        <omgdc:Bounds x="120" y="952" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- IT: Task 1 - Meldedaten abrufen -->
      <bpmndi:BPMNShape bpmnElement="_it_task1_wu01">
        <omgdc:Bounds x="220" y="932" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- IT: Task 2 - Adressdaten aktualisieren -->
      <bpmndi:BPMNShape bpmnElement="_it_task2_wu01">
        <omgdc:Bounds x="441" y="932" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- IT: Task 3 - Ummeldebestätigung erzeugen -->
      <bpmndi:BPMNShape bpmnElement="_it_task3_wu01">
        <omgdc:Bounds x="662" y="932" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- IT: End Event -->
      <bpmndi:BPMNShape bpmnElement="_it_end_wu01">
        <omgdc:Bounds x="883" y="952" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- IT: Sequence Flows -->
      <bpmndi:BPMNEdge bpmnElement="_it_flow1_wu01">
        <omgdi:waypoint x="156" y="970"/>
        <omgdi:waypoint x="220" y="970"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_it_flow2_wu01">
        <omgdi:waypoint x="371" y="970"/>
        <omgdi:waypoint x="441" y="970"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_it_flow3_wu01">
        <omgdi:waypoint x="592" y="970"/>
        <omgdi:waypoint x="662" y="970"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_it_flow4_wu01">
        <omgdi:waypoint x="813" y="970"/>
        <omgdi:waypoint x="883" y="970"/>
      </bpmndi:BPMNEdge>

      <!-- ===== MESSAGE FLOWS ===== -->

      <!-- Kunde Task 2 → Organisation Start: Ummeldungsantrag -->
      <bpmndi:BPMNEdge bpmnElement="_msgflow_k_o_wu01">
        <omgdi:waypoint x="516" y="228"/>
        <omgdi:waypoint x="516" y="390"/>
        <omgdi:waypoint x="138" y="390"/>
        <omgdi:waypoint x="138" y="562"/>
      </bpmndi:BPMNEdge>

      <!-- Organisation Task 3 → IT Start: Geprüfte Ummeldedaten -->
      <bpmndi:BPMNEdge bpmnElement="_msgflow_o_it_wu01">
        <omgdi:waypoint x="737" y="618"/>
        <omgdi:waypoint x="737" y="780"/>
        <omgdi:waypoint x="138" y="780"/>
        <omgdi:waypoint x="138" y="952"/>
      </bpmndi:BPMNEdge>

      <!-- IT Task 3 → Organisation Task 4: Ummeldebestätigung -->
      <bpmndi:BPMNEdge bpmnElement="_msgflow_it_o_wu01">
        <omgdi:waypoint x="737" y="932"/>
        <omgdi:waypoint x="737" y="780"/>
        <omgdi:waypoint x="958" y="780"/>
        <omgdi:waypoint x="958" y="618"/>
      </bpmndi:BPMNEdge>

      <!-- Organisation Task 4 → Kunde Task 3: Ummeldebestätigung -->
      <bpmndi:BPMNEdge bpmnElement="_msgflow_o_k_wu01">
        <omgdi:waypoint x="958" y="542"/>
        <omgdi:waypoint x="958" y="390"/>
        <omgdi:waypoint x="737" y="390"/>
        <omgdi:waypoint x="737" y="228"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
