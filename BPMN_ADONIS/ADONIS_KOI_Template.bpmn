              targetNamespace="http://www.boc-group.com">
   <!-- =====================================================
        COLLABORATION - ADONIS KOI Prozessmodell
        ===================================================== -->
   <collaboration id="Collaboration_[UUID]"
                   name="[PROZESSNAME]"
                   isClosed="false">
      <extensionElements>
         <adonis:modelattributes>
            <adonis:attribute name="A_COMPLIANCE" type="ENUM" notebook="1" sourcelang="" novalue="0" lang-independent="v4">
