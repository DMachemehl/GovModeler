               <adonis:attribute name="REPRESENTATION_HAS_PROCESS" type="ENUM" notebook="1" sourcelang="" novalue="0" lang-independent="v0">
                  <adonis:value>automatisch</adonis:value>
                  <adonis:metavalue/>
               </adonis:attribute>
            </adonis:connector>
         </extensionElements>
      </messageFlow>
      <messageFlow id="_[UUID_MF2]" sourceRef="_[TASK_IT_BESCHEID]" targetRef="_[EVENT_KUNDE_BESCHEID]">
