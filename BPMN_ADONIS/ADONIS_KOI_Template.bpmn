      <participant processRef="process_[UUID_ORGA]" name="Organisation" id="_[UUID_ORGA]"/>
      <participant processRef="process_[UUID_IT]" name="IT" id="_[UUID_IT]"/>
      <participant processRef="process_[UUID_KUNDE]" name="Kunde" id="_[UUID_KUNDE]"/>
      <!-- Message Flows -->
      <messageFlow id="_[UUID_MF1]" sourceRef="_[TASK_KUNDE_ANTRAG]" targetRef="_[EVENT_IT_START]">
         <extensionElements>
            <adonis:connector>
               <adonis:attribute name="DISPLAY_DENOMNIATION" type="BOOL" notebook="1" sourcelang="" novalue="0">
                  <adonis:value>true</adonis:value>
                  <adonis:metavalue/>
