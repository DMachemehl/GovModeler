               <adonis:metavalue/>
            </adonis:attribute>
            <adonis:attribute name="A_DISPLAY_WATERMARK" type="BOOL" notebook="1" sourcelang="" novalue="0">
               <adonis:value>false</adonis:value>
               <adonis:metavalue/>
            </adonis:attribute>
            <adonis:attribute name="A_NEED_FOR_ACTION_CS" type="BOOL" notebook="1" sourcelang="" novalue="0">
               <adonis:value>false</adonis:value>
               <adonis:metavalue/>
            </adonis:attribute>
            <adonis:attribute name="FONT_COLOUR" type="INTEGER" notebook="0" sourcelang="" novalue="0">
               <adonis:value>0</adonis:value>
               <adonis:metavalue/>
            </adonis:attribute>
            <adonis:attribute name="IS_CLOSED" type="BOOL" notebook="1" sourcelang="" novalue="0">
               <adonis:value>false</adonis:value>
               <adonis:metavalue/>
            </adonis:attribute>
            <adonis:attribute name="MULTIPLICITY_MAX" type="INTEGER" notebook="1" sourcelang="" novalue="0">
               <adonis:value>1</adonis:value>
               <adonis:metavalue/>
            </adonis:attribute>
            <adonis:attribute name="AUDITING" type="BOOL" notebook="1" sourcelang="" novalue="0">
               <adonis:value>false</adonis:value>
               <adonis:metavalue/>
            </adonis:attribute>
            <adonis:attribute name="MULTIPLICITY_MIN" type="INTEGER" notebook="1" sourcelang="" novalue="0">
               <adonis:value>0</adonis:value>
               <adonis:metavalue/>
            </adonis:attribute>
            <adonis:attribute name="VISUALIZED_VALUES_POOL" type="ENUM" notebook="1" sourcelang="" novalue="0" lang-independent="v0">
               <adonis:value>Keiner</adonis:value>
               <adonis:metavalue/>
            </adonis:attribute>
            <adonis:attribute name="IS_EXECUTABLE" type="BOOL" notebook="1" sourcelang="" novalue="0">
               <adonis:value>false</adonis:value>
               <adonis:metavalue/>
            </adonis:attribute>
            <adonis:record name="A_ATTACHMENT_LIST_CS"/>
            <adonis:record name="OPEN_QUESTIONS"/>
         </adonis:instance>
      </extensionElements>
      <laneSet id="laneSet_[UUID_KUNDE]">
         <lane name="Bahn" id="_[UUID_LANE_KUNDE]">
            <extensionElements>
               <adonis:instance>
                  <adonis:attribute name="IDENTIFICATION_OF_CHANGES" type="ENUM" notebook="1" sourcelang="" novalue="0" lang-independent="v0">
                     <adonis:value>Keine Änderung</adonis:value>
                     <adonis:metavalue/>
                  </adonis:attribute>
                  <adonis:attribute name="A_GRADIENT" type="BOOL" notebook="1" sourcelang="" novalue="0">
                     <adonis:value>false</adonis:value>
                     <adonis:metavalue/>
                  </adonis:attribute>
                  <adonis:attribute name="COLOUR" type="INTEGER" notebook="1" sourcelang="" novalue="0">
                     <adonis:value>16777215</adonis:value>
                     <adonis:metavalue/>
                  </adonis:attribute>
                  <adonis:attribute name="A_DISPLAY_WATERMARK" type="BOOL" notebook="1" sourcelang="" novalue="0">
                     <adonis:value>false</adonis:value>
                     <adonis:metavalue/>
                  </adonis:attribute>
                  <adonis:attribute name="A_NEED_FOR_ACTION_CS" type="BOOL" notebook="1" sourcelang="" novalue="0">
                     <adonis:value>false</adonis:value>
                     <adonis:metavalue/>
                  </adonis:attribute>
                  <adonis:attribute name="FONT_COLOUR" type="INTEGER" notebook="0" sourcelang="" novalue="0">
                     <adonis:value>0</adonis:value>
                     <adonis:metavalue/>
                  </adonis:attribute>
                  <adonis:attribute name="VISUALIZED_VALUES_POOL" type="ENUM" notebook="1" sourcelang="" novalue="0" lang-independent="v0">
                     <adonis:value>Keiner</adonis:value>
                     <adonis:metavalue/>
                  </adonis:attribute>
                  <adonis:record name="A_ATTACHMENT_LIST_CS"/>
                  <adonis:record name="OPEN_QUESTIONS"/>
               </adonis:instance>
            </extensionElements>
            <!-- flowNodeRef Elemente hier einfuegen -->
         </lane>
      </laneSet>
      <!-- Start Event, Tasks, End Event, Sequence Flows hier einfuegen -->
   </process>
   <!-- =====================================================
        BPMN-DI: Diagramm-Visualisierung
        
        ADONIS Koordinatensystem:
        - Kunde-Pool: y=0, Hoehe=170
        - IT-Pool (Lane): y=208, Hoehe=171
        - Organisation-Pool: y=417, Hoehe=152
        
        Task-Dimensionen: 151x76
        Event-Dimensionen: 56x56
        
        Horizontaler Abstand zwischen Tasks: ca. 190px
        Erster Task x-Position: ca. 209-341
        ===================================================== -->
   <bpmndi:BPMNDiagram name="[PROZESSNAME]" id="Diagram_[UUID]">
      <bpmndi:BPMNPlane id="BPMNPlane_[UUID]" bpmnElement="Collaboration_[UUID]">
         <!-- Kunde Pool und Lane -->
         <bpmndi:BPMNShape bpmnElement="_[UUID_LANE_KUNDE]" isHorizontal="true" id="BPMN_Shape_Lane_Kunde">
            <omgdc:Bounds height="170" width="1837" x="0" y="0"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="_[UUID_KUNDE]" isHorizontal="true" id="BPMN_Shape_Pool_Kunde">
            <omgdc:Bounds height="170" width="1837" x="0" y="0"/>
         </bpmndi:BPMNShape>
         <!-- IT Pool und Lane -->
         <bpmndi:BPMNShape bpmnElement="_[UUID_LANE_IT]" isHorizontal="true" id="BPMN_Shape_Lane_IT">
            <omgdc:Bounds height="171" width="1797" x="40" y="208"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="_[UUID_IT]" isHorizontal="true" id="BPMN_Shape_Pool_IT">
            <omgdc:Bounds height="171" width="1837" x="0" y="208"/>
         </bpmndi:BPMNShape>
         <!-- Organisation Pool und Lane -->
         <bpmndi:BPMNShape bpmnElement="_[UUID_LANE_ORGA]" isHorizontal="true" id="BPMN_Shape_Lane_Orga">
            <omgdc:Bounds height="152" width="1797" x="40" y="417"/>
         </bpmndi:BPMNShape>
         <bpmndi:BPMNShape bpmnElement="_[UUID_ORGA]" isHorizontal="true" id="BPMN_Shape_Pool_Orga">
            <omgdc:Bounds height="152" width="1837" x="0" y="417"/>
         </bpmndi:BPMNShape>
         <!-- Shapes und Edges hier einfuegen -->
         <!--
         Task Y-Koordinaten:
           Kunde-Tasks: y=38 (Hoehe 76)
           IT-Tasks: y=246 (Hoehe 76)
           Organisation-Tasks: y=435 (Hoehe 76)
         
         Event Y-Koordinaten:
           Kunde-Events: y=48 (Hoehe 56)
           IT-Events: y=256 (Hoehe 56)
           Organisation-Events: y=446 (Hoehe 56)
         
         Horizontale Positionen (x):
           Start Event: x=105
           Task 1: x=209
           Task 2: x=530 (oder naechster Abstand)
           Task 3: x=720
           Task 4: x=909
           Task 5: x=1098
           End Event: x=1430-1752
         -->
      </bpmndi:BPMNPlane>
   </bpmndi:BPMNDiagram>
</definitions>
