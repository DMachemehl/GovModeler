  <bpmn:process id="Process_Buerger" name="Parkausweis_fuer_Schwerbehinderte_beantragen_Buerger" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Buerger" name="Bedarf an Parkausweis festgestellt">
      <bpmn:outgoing>Flow_Buerger_Start_Ausfuellen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Antrag_ausfuellen" name="Antrag ausfuellen">
      <bpmn:incoming>Flow_Buerger_Start_Ausfuellen</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Ausfuellen_Hochladen</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Schwerbehindertenausweis_hochladen" name="Schwerbehindertenausweis hochladen">
      <bpmn:incoming>Flow_Buerger_Ausfuellen_Hochladen</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Hochladen_Absenden</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Antrag_absenden" name="Antrag absenden">
      <bpmn:incoming>Flow_Buerger_Hochladen_Absenden</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Absenden_Bescheid</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="Event_Bescheid_erhalten" name="Bescheid erhalten">
      <bpmn:incoming>Flow_Buerger_Absenden_Bescheid</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Bescheid_Ende</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDef_Bescheid" messageRef="Message_Bescheid" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_Buerger" name="Parkausweis erhalten">
      <bpmn:incoming>Flow_Buerger_Bescheid_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Buerger_Start_Ausfuellen" sourceRef="StartEvent_Buerger" targetRef="Task_Antrag_ausfuellen" />
    <bpmn:sequenceFlow id="Flow_Buerger_Ausfuellen_Hochladen" sourceRef="Task_Antrag_ausfuellen" targetRef="Task_Schwerbehindertenausweis_hochladen" />
    <bpmn:sequenceFlow id="Flow_Buerger_Hochladen_Absenden" sourceRef="Task_Schwerbehindertenausweis_hochladen" targetRef="Task_Antrag_absenden" />
    <bpmn:sequenceFlow id="Flow_Buerger_Absenden_Bescheid" sourceRef="Task_Antrag_absenden" targetRef="Event_Bescheid_erhalten" />
    <bpmn:sequenceFlow id="Flow_Buerger_Bescheid_Ende" sourceRef="Event_Bescheid_erhalten" targetRef="EndEvent_Buerger" />
