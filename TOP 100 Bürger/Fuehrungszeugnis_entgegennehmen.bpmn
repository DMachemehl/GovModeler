    </bpmn:serviceTask>
    <bpmn:userTask id="Task_Weiterleitung_veranlassen" name="Weiterleitung veranlassen">
      <bpmn:incoming>Flow_Behoerde_Vollstaendigkeit_Veranlassen</bpmn:incoming>
      <bpmn:outgoing>Flow_Behoerde_Veranlassen_Bestaetigung</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="Event_Weiterleitungsbestaetigung_erhalten" name="Weiterleitungsbestaetigung erhalten">
      <bpmn:incoming>Flow_Behoerde_Veranlassen_Bestaetigung</bpmn:incoming>
      <bpmn:outgoing>Flow_Behoerde_Bestaetigung_Versenden</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDef_Weiterleitungsbestaetigung" messageRef="Message_Weiterleitungsbestaetigung" />
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="Task_Bestaetigung_versenden" name="Bestaetigung versenden">
      <bpmn:incoming>Flow_Behoerde_Bestaetigung_Versenden</bpmn:incoming>
      <bpmn:outgoing>Flow_Behoerde_Versenden_Ende</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Behoerde" name="Antrag an Bundesamt fuer Justiz weitergeleitet">
      <bpmn:incoming>Flow_Behoerde_Versenden_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Behoerde_Start_Zustaendigkeit" sourceRef="StartEvent_Antrag_eingegangen" targetRef="Task_Zustaendigkeit_pruefen" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Zustaendigkeit_Entgegennehmen" sourceRef="Task_Zustaendigkeit_pruefen" targetRef="Task_Antrag_entgegennehmen" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Entgegennehmen_Vollstaendigkeit" sourceRef="Task_Antrag_entgegennehmen" targetRef="Task_Vollstaendigkeit_pruefen" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Vollstaendigkeit_Veranlassen" sourceRef="Task_Vollstaendigkeit_pruefen" targetRef="Task_Weiterleitung_veranlassen" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Veranlassen_Bestaetigung" sourceRef="Task_Weiterleitung_veranlassen" targetRef="Event_Weiterleitungsbestaetigung_erhalten" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Bestaetigung_Versenden" sourceRef="Event_Weiterleitungsbestaetigung_erhalten" targetRef="Task_Bestaetigung_versenden" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Versenden_Ende" sourceRef="Task_Bestaetigung_versenden" targetRef="EndEvent_Behoerde" />
