  <bpmn:collaboration id="Collab_Fuehrungszeugnis_entgegennehmen">
    <bpmn:participant id="Participant_Buerger" name="Buerger" processRef="Process_Buerger" />
    <bpmn:participant id="Participant_IT" name="IT" processRef="Process_IT" />
    <bpmn:participant id="Participant_Behoerde" name="Meldebehoerde" processRef="Process_Behoerde" />
    <bpmn:messageFlow id="MsgFlow_Antrag" name="Fuehrungszeugnis-Antrag" sourceRef="Task_Antrag_absenden" targetRef="StartEvent_Antrag_eingegangen" />
    <bpmn:messageFlow id="MsgFlow_Weiterleitungsauftrag" name="Weiterleitungsauftrag" sourceRef="Task_Weiterleitung_veranlassen" targetRef="StartEvent_Antragsdaten_erhalten" />
    <bpmn:messageFlow id="MsgFlow_Weiterleitungsbestaetigung" name="Weiterleitungsbestaetigung" sourceRef="Task_Weiterleitung_protokollieren" targetRef="Event_Weiterleitungsbestaetigung_erhalten" />
    <bpmn:messageFlow id="MsgFlow_Eingangsbestaetigung" name="Eingangsbestaetigung" sourceRef="Task_Bestaetigung_versenden" targetRef="Event_Eingangsbestaetigung_erhalten" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Buerger" name="Fuehrungszeugnis_entgegennehmen_Buerger" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Buerger" name="Bedarf an Fuehrungszeugnis festgestellt">
      <bpmn:outgoing>Flow_Buerger_Start_Ausfuellen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Antrag_ausfuellen" name="Antrag ausfuellen">
      <bpmn:incoming>Flow_Buerger_Start_Ausfuellen</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Ausfuellen_Nachweis</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Identitaet_nachweisen" name="Identitaet nachweisen">
      <bpmn:incoming>Flow_Buerger_Ausfuellen_Nachweis</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Nachweis_Gebuehr</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Gebuehr_entrichten" name="Gebuehr entrichten">
      <bpmn:incoming>Flow_Buerger_Nachweis_Gebuehr</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Gebuehr_Absenden</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Antrag_absenden" name="Antrag absenden">
      <bpmn:incoming>Flow_Buerger_Gebuehr_Absenden</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Absenden_Bestaetigung</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="Event_Eingangsbestaetigung_erhalten" name="Eingangsbestaetigung erhalten">
      <bpmn:incoming>Flow_Buerger_Absenden_Bestaetigung</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Bestaetigung_Ende</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDef_Eingangsbestaetigung" messageRef="Message_Eingangsbestaetigung" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_Buerger" name="Antrag weitergeleitet">
      <bpmn:incoming>Flow_Buerger_Bestaetigung_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Buerger_Start_Ausfuellen" sourceRef="StartEvent_Buerger" targetRef="Task_Antrag_ausfuellen" />
    <bpmn:sequenceFlow id="Flow_Buerger_Ausfuellen_Nachweis" sourceRef="Task_Antrag_ausfuellen" targetRef="Task_Identitaet_nachweisen" />
    <bpmn:sequenceFlow id="Flow_Buerger_Nachweis_Gebuehr" sourceRef="Task_Identitaet_nachweisen" targetRef="Task_Gebuehr_entrichten" />
    <bpmn:sequenceFlow id="Flow_Buerger_Gebuehr_Absenden" sourceRef="Task_Gebuehr_entrichten" targetRef="Task_Antrag_absenden" />
    <bpmn:sequenceFlow id="Flow_Buerger_Absenden_Bestaetigung" sourceRef="Task_Antrag_absenden" targetRef="Event_Eingangsbestaetigung_erhalten" />
    <bpmn:sequenceFlow id="Flow_Buerger_Bestaetigung_Ende" sourceRef="Event_Eingangsbestaetigung_erhalten" targetRef="EndEvent_Buerger" />
  </bpmn:process>

  <bpmn:process id="Process_IT" name="Fuehrungszeugnis_entgegennehmen_IT" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Antragsdaten_erhalten" name="Antragsdaten erhalten">
      <bpmn:outgoing>Flow_IT_Start_Erfassen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Antragsdaten_erfassen" name="Antragsdaten erfassen">
      <bpmn:incoming>Flow_IT_Start_Erfassen</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Erfassen_Abgleichen</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Identitaet_abgleichen" name="Identitaet abgleichen">
      <bpmn:incoming>Flow_IT_Erfassen_Abgleichen</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Abgleichen_Weiterleiten</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Antrag_weiterleiten" name="Antrag weiterleiten">
      <bpmn:incoming>Flow_IT_Abgleichen_Weiterleiten</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Weiterleiten_Protokollieren</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Weiterleitung_protokollieren" name="Weiterleitung protokollieren">
      <bpmn:incoming>Flow_IT_Weiterleiten_Protokollieren</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Protokollieren_Ende</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_IT" name="Weiterleitung abgeschlossen">
      <bpmn:incoming>Flow_IT_Protokollieren_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_IT_Start_Erfassen" sourceRef="StartEvent_Antragsdaten_erhalten" targetRef="Task_Antragsdaten_erfassen" />
    <bpmn:sequenceFlow id="Flow_IT_Erfassen_Abgleichen" sourceRef="Task_Antragsdaten_erfassen" targetRef="Task_Identitaet_abgleichen" />
    <bpmn:sequenceFlow id="Flow_IT_Abgleichen_Weiterleiten" sourceRef="Task_Identitaet_abgleichen" targetRef="Task_Antrag_weiterleiten" />
    <bpmn:sequenceFlow id="Flow_IT_Weiterleiten_Protokollieren" sourceRef="Task_Antrag_weiterleiten" targetRef="Task_Weiterleitung_protokollieren" />
    <bpmn:sequenceFlow id="Flow_IT_Protokollieren_Ende" sourceRef="Task_Weiterleitung_protokollieren" targetRef="EndEvent_IT" />
  </bpmn:process>

  <bpmn:process id="Process_Behoerde" name="Fuehrungszeugnis_entgegennehmen_Behoerde" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Antrag_eingegangen" name="Antrag eingegangen">
