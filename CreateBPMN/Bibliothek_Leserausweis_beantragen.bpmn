<?xml version="1.0" encoding="utf-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:adonis="http://www.boc-group.com"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definition__Bibliothek_Leserausweis_beantragen"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd"
             targetNamespace="http://www.boc-group.com">

  <!-- =====================================================
       COLLABORATION
       Stadtbibliothek Stuttgart - Leserausweis beantragen
       3-Pool: Kunde (Black-Box), Organisation (White-Box), IT/aDIS-BMS (Black-Box)
       ===================================================== -->
  <collaboration id="Collab_Leserausweis"
                 name="Stadtbibliothek Stuttgart - Leserausweis beantragen"
                 isClosed="false">

    <participant processRef="process_Kund"
                 name="Kunde"
                 id="_Kund_Part"/>
    <participant processRef="process_Org"
                 name="Organisation"
                 id="_Org_Part"/>
    <participant processRef="process_IT"
                 name="IT (aDIS/BMS)"
                 id="_IT_Part"/>

    <!-- Message Flows -->
    <messageFlow id="_MsgFlow_KO_01"
                 name="Leserausweis-Antrag"
                 sourceRef="_Kund_Part"
                 targetRef="_StartEvt"/>
    <messageFlow id="_MsgFlow_OI_01"
                 name="Kontoanlage-Auftrag"
                 sourceRef="_Task_Benutzerkonto"
                 targetRef="_IT_Part"/>
    <messageFlow id="_MsgFlow_IO_01"
                 name="Kontobestaetigung"
                 sourceRef="_IT_Part"
                 targetRef="_IntermCatch"/>
    <messageFlow id="_MsgFlow_OK_01"
                 name="Leserausweis ausgehaendigt"
                 sourceRef="_EndEvt"
                 targetRef="_Kund_Part"/>

  </collaboration>

  <!-- =====================================================
       PROZESS: Kunde (Black-Box Pool)
       Keine internen Prozesselemente
       ===================================================== -->
  <process name="Kunde"
           id="process_Kund"
           isExecutable="false"
           isClosed="false"
           processType="None">
  </process>

  <!-- =====================================================
       PROZESS: Organisation (White-Box Pool)
       Lane: Ausleihe
       ===================================================== -->
  <process name="Organisation"
           id="process_Org"
           isExecutable="false"
           isClosed="false"
           processType="None">

    <laneSet id="laneSet_Org">
      <lane name="Ausleihe" id="_Lane_Ausleihe">
        <flowNodeRef>_StartEvt</flowNodeRef>
        <flowNodeRef>_Task_Personalien</flowNodeRef>
        <flowNodeRef>_Task_Identitaet</flowNodeRef>
        <flowNodeRef>_Task_Benutzerkonto</flowNodeRef>
        <flowNodeRef>_IntermCatch</flowNodeRef>
        <flowNodeRef>_Task_Drucken</flowNodeRef>
        <flowNodeRef>_Task_Gebuehr</flowNodeRef>
        <flowNodeRef>_EndEvt</flowNodeRef>
      </lane>
    </laneSet>

    <!-- Start Event: Message (Leserausweis-Antrag eingegangen) -->
    <startEvent name="Leserausweis-Antrag eingegangen"
                id="_StartEvt">
      <outgoing>_SeqFlow_01</outgoing>
      <messageEventDefinition id="_MsgEvtDef_Start"/>
    </startEvent>

    <!-- Task 1: Personalien erfassen -->
    <userTask name="Personalien erfassen"
              id="_Task_Personalien"
              isForCompensation="false">
      <incoming>_SeqFlow_01</incoming>
      <outgoing>_SeqFlow_02</outgoing>
    </userTask>

    <!-- Task 2: Identitaet pruefen -->
    <userTask name="Identitaet pruefen"
              id="_Task_Identitaet"
              isForCompensation="false">
      <incoming>_SeqFlow_02</incoming>
      <outgoing>_SeqFlow_03</outgoing>
    </userTask>

    <!-- Task 3: Benutzerkonto anlegen (sendet Kontoanlage-Auftrag an aDIS/BMS) -->
    <serviceTask name="Benutzerkonto anlegen"
                 id="_Task_Benutzerkonto"
                 isForCompensation="false">
      <incoming>_SeqFlow_03</incoming>
      <outgoing>_SeqFlow_04</outgoing>
    </serviceTask>

    <!-- Intermediate Catch Event: Kontobestaetigung erhalten (von aDIS/BMS) -->
    <intermediateCatchEvent name="Kontobestaetigung erhalten"
                            id="_IntermCatch">
      <incoming>_SeqFlow_04</incoming>
      <outgoing>_SeqFlow_05</outgoing>
      <messageEventDefinition id="_MsgEvtDef_Catch"/>
    </intermediateCatchEvent>

    <!-- Task 4: Leserausweis drucken -->
    <userTask name="Leserausweis drucken"
              id="_Task_Drucken"
              isForCompensation="false">
      <incoming>_SeqFlow_05</incoming>
      <outgoing>_SeqFlow_06</outgoing>
    </userTask>

    <!-- Task 5: Gebuehr kassieren -->
    <userTask name="Gebuehr kassieren"
              id="_Task_Gebuehr"
              isForCompensation="false">
      <incoming>_SeqFlow_06</incoming>
      <outgoing>_SeqFlow_07</outgoing>
    </userTask>

    <!-- End Event: Message (Leserausweis ausgehaendigt) -->
    <endEvent name="Leserausweis ausgestellt"
              id="_EndEvt">
      <incoming>_SeqFlow_07</incoming>
      <messageEventDefinition id="_MsgEvtDef_End"/>
    </endEvent>

    <!-- Sequence Flows -->
    <sequenceFlow sourceRef="_StartEvt"          targetRef="_Task_Personalien"   id="_SeqFlow_01"/>
    <sequenceFlow sourceRef="_Task_Personalien"  targetRef="_Task_Identitaet"    id="_SeqFlow_02"/>
    <sequenceFlow sourceRef="_Task_Identitaet"   targetRef="_Task_Benutzerkonto" id="_SeqFlow_03"/>
    <sequenceFlow sourceRef="_Task_Benutzerkonto" targetRef="_IntermCatch"       id="_SeqFlow_04"/>
    <sequenceFlow sourceRef="_IntermCatch"        targetRef="_Task_Drucken"      id="_SeqFlow_05"/>
    <sequenceFlow sourceRef="_Task_Drucken"       targetRef="_Task_Gebuehr"      id="_SeqFlow_06"/>
    <sequenceFlow sourceRef="_Task_Gebuehr"       targetRef="_EndEvt"            id="_SeqFlow_07"/>

  </process>

  <!-- =====================================================
       PROZESS: IT / aDIS-BMS (Black-Box Pool)
       Keine internen Prozesselemente
       ===================================================== -->
  <process name="IT (aDIS/BMS)"
           id="process_IT"
           isExecutable="false"
           isClosed="false"
           processType="None">
  </process>

  <!-- =====================================================
       BPMN-DI: Visuelle Darstellung
       Pool-Anordnung vertikal:
         Kunde       y=80,  h=100
         Organisation y=200, h=250
         IT          y=470, h=100
       Pool-Breite: 1250px
       Tasks: y=285 (80px hoch), Zentrum y=325
       Events/Intermediate: y=307 (36px), Zentrum y=325
       Horizontaler Abstand Tasks: 150px (100 Breite + 50 Abstand)
       ===================================================== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_Leserausweis"
                       name="Stadtbibliothek Stuttgart - Leserausweis beantragen">
    <bpmndi:BPMNPlane id="BPMNPlane_Leserausweis"
                      bpmnElement="Collab_Leserausweis">

      <!-- ================================================
           POOL: Kunde (Black-Box, oben)
           ================================================ -->
      <bpmndi:BPMNShape id="_Kund_Part_di"
                        bpmnElement="_Kund_Part"
                        isHorizontal="true">
        <omgdc:Bounds x="160" y="80" width="1250" height="100"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="161" y="120" width="29" height="20"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ================================================
           POOL: Organisation (White-Box, Mitte)
           ================================================ -->
      <bpmndi:BPMNShape id="_Org_Part_di"
                        bpmnElement="_Org_Part"
                        isHorizontal="true">
        <omgdc:Bounds x="160" y="200" width="1250" height="250"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="161" y="315" width="29" height="40"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Lane: Ausleihe -->
      <bpmndi:BPMNShape id="_Lane_Ausleihe_di"
                        bpmnElement="_Lane_Ausleihe"
                        isHorizontal="true">
        <omgdc:Bounds x="190" y="200" width="1220" height="250"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="191" y="315" width="29" height="40"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ================================================
           POOL: IT / aDIS-BMS (Black-Box, unten)
           ================================================ -->
      <bpmndi:BPMNShape id="_IT_Part_di"
                        bpmnElement="_IT_Part"
                        isHorizontal="true">
        <omgdc:Bounds x="160" y="470" width="1250" height="100"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="161" y="510" width="29" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ================================================
           PROZESSELEMENTE: Organisation / Ausleihe
           Zentrum-Y aller Elemente: 325
           ================================================ -->

      <!-- START EVENT (Message): x=228, y=307 -->
      <bpmndi:BPMNShape id="_StartEvt_di"
                        bpmnElement="_StartEvt">
        <omgdc:Bounds x="228" y="307" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="198" y="350" width="96" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- TASK 1: Personalien erfassen x=314, y=285 -->
      <bpmndi:BPMNShape id="_Task_Personalien_di"
                        bpmnElement="_Task_Personalien">
        <omgdc:Bounds x="314" y="285" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- TASK 2: Identitaet pruefen x=464, y=285 -->
      <bpmndi:BPMNShape id="_Task_Identitaet_di"
                        bpmnElement="_Task_Identitaet">
        <omgdc:Bounds x="464" y="285" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- TASK 3: Benutzerkonto anlegen x=614, y=285 -->
      <bpmndi:BPMNShape id="_Task_Benutzerkonto_di"
                        bpmnElement="_Task_Benutzerkonto">
        <omgdc:Bounds x="614" y="285" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- INTERMEDIATE CATCH (Message): Kontobestaetigung x=764, y=307 -->
      <bpmndi:BPMNShape id="_IntermCatch_di"
                        bpmnElement="_IntermCatch">
        <omgdc:Bounds x="764" y="307" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="734" y="350" width="96" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- TASK 4: Leserausweis drucken x=850, y=285 -->
      <bpmndi:BPMNShape id="_Task_Drucken_di"
                        bpmnElement="_Task_Drucken">
        <omgdc:Bounds x="850" y="285" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- TASK 5: Gebuehr kassieren x=1000, y=285 -->
      <bpmndi:BPMNShape id="_Task_Gebuehr_di"
                        bpmnElement="_Task_Gebuehr">
        <omgdc:Bounds x="1000" y="285" width="100" height="80"/>
        <bpmndi:BPMNLabel/>
      </bpmndi:BPMNShape>

      <!-- END EVENT (Message): Leserausweis ausgestellt x=1150, y=307 -->
      <bpmndi:BPMNShape id="_EndEvt_di"
                        bpmnElement="_EndEvt">
        <omgdc:Bounds x="1150" y="307" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1120" y="350" width="96" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ================================================
           SEQUENCE FLOWS
           ================================================ -->
      <bpmndi:BPMNEdge id="_SeqFlow_01_di" bpmnElement="_SeqFlow_01">
        <omgdi:waypoint x="264" y="325"/>
        <omgdi:waypoint x="314" y="325"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="_SeqFlow_02_di" bpmnElement="_SeqFlow_02">
        <omgdi:waypoint x="414" y="325"/>
        <omgdi:waypoint x="464" y="325"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="_SeqFlow_03_di" bpmnElement="_SeqFlow_03">
        <omgdi:waypoint x="564" y="325"/>
        <omgdi:waypoint x="614" y="325"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="_SeqFlow_04_di" bpmnElement="_SeqFlow_04">
        <omgdi:waypoint x="714" y="325"/>
        <omgdi:waypoint x="764" y="325"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="_SeqFlow_05_di" bpmnElement="_SeqFlow_05">
        <omgdi:waypoint x="800" y="325"/>
        <omgdi:waypoint x="850" y="325"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="_SeqFlow_06_di" bpmnElement="_SeqFlow_06">
        <omgdi:waypoint x="950" y="325"/>
        <omgdi:waypoint x="1000" y="325"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="_SeqFlow_07_di" bpmnElement="_SeqFlow_07">
        <omgdi:waypoint x="1100" y="325"/>
        <omgdi:waypoint x="1150" y="325"/>
      </bpmndi:BPMNEdge>

      <!-- ================================================
           MESSAGE FLOWS
           ================================================ -->

      <!-- Kunde → StartEvent: Leserausweis-Antrag -->
      <bpmndi:BPMNEdge id="_MsgFlow_KO_01_di" bpmnElement="_MsgFlow_KO_01">
        <omgdi:waypoint x="246" y="180"/>
        <omgdi:waypoint x="246" y="307"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="255" y="228" width="89" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Task Benutzerkonto anlegen → IT: Kontoanlage-Auftrag -->
      <bpmndi:BPMNEdge id="_MsgFlow_OI_01_di" bpmnElement="_MsgFlow_OI_01">
        <omgdi:waypoint x="664" y="365"/>
        <omgdi:waypoint x="664" y="470"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="673" y="408" width="89" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- IT → IntermCatch: Kontobestaetigung -->
      <bpmndi:BPMNEdge id="_MsgFlow_IO_01_di" bpmnElement="_MsgFlow_IO_01">
        <omgdi:waypoint x="782" y="470"/>
        <omgdi:waypoint x="782" y="343"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="791" y="400" width="89" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- EndEvent → Kunde: Leserausweis ausgehaendigt -->
      <bpmndi:BPMNEdge id="_MsgFlow_OK_01_di" bpmnElement="_MsgFlow_OK_01">
        <omgdi:waypoint x="1168" y="307"/>
        <omgdi:waypoint x="1168" y="180"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1177" y="228" width="89" height="27"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
