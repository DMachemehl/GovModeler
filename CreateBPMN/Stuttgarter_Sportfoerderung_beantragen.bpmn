<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://example.com/bpmn" exporter="GitHub-Copilot-GovModeler" exporterVersion="2.0">
  <bpmn:collaboration id="Collab_Stuttgarter_Sportfoerderung_beantragen">
    <bpmn:participant id="Participant_Buerger" name="Buerger" processRef="Process_Buerger" />
    <bpmn:participant id="Participant_IT" name="IT" processRef="Process_IT" />
    <bpmn:participant id="Participant_Behoerde" name="Behoerde" processRef="Process_Behoerde" />
    <bpmn:messageFlow id="MsgFlow_Antrag" name="Foerderantrag" sourceRef="Task_Antrag_einreichen" targetRef="StartEvent_IT_Antrag_eingegangen" />
    <bpmn:messageFlow id="MsgFlow_Antragsdaten" name="Antragsdaten" sourceRef="Task_Antragsdaten_uebermitteln" targetRef="StartEvent_Behoerde_Antrag_eingegangen" />
    <bpmn:messageFlow id="MsgFlow_Bescheid_IT" name="Foerderbescheid" sourceRef="Task_Bescheid_erstellen" targetRef="Event_Bescheid_eingegangen" />
    <bpmn:messageFlow id="MsgFlow_Bescheid_Buerger" name="Foerderbescheid" sourceRef="Task_Bescheid_bereitstellen" targetRef="Event_Bescheid_empfangen" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Buerger" name="Stuttgarter_Sportfoerderung_beantragen_Buerger" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Buerger" name="Foerderbedarf festgestellt">
      <bpmn:outgoing>Flow_Start_Vorbereiten</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Antrag_vorbereiten" name="Antrag vorbereiten">
      <bpmn:incoming>Flow_Start_Vorbereiten</bpmn:incoming>
      <bpmn:outgoing>Flow_Vorbereiten_Einreichen</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Antrag_einreichen" name="Antrag einreichen">
      <bpmn:incoming>Flow_Vorbereiten_Einreichen</bpmn:incoming>
      <bpmn:outgoing>Flow_Einreichen_Warten</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="Event_Bescheid_empfangen" name="Bescheid empfangen">
      <bpmn:incoming>Flow_Einreichen_Warten</bpmn:incoming>
      <bpmn:outgoing>Flow_Bescheid_Ende_Buerger</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDef_Bescheid_Buerger" messageRef="Message_Foerderbescheid" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_Buerger" name="Foerderbescheid zugestellt">
      <bpmn:incoming>Flow_Bescheid_Ende_Buerger</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Vorbereiten" sourceRef="StartEvent_Buerger" targetRef="Task_Antrag_vorbereiten" />
    <bpmn:sequenceFlow id="Flow_Vorbereiten_Einreichen" sourceRef="Task_Antrag_vorbereiten" targetRef="Task_Antrag_einreichen" />
    <bpmn:sequenceFlow id="Flow_Einreichen_Warten" sourceRef="Task_Antrag_einreichen" targetRef="Event_Bescheid_empfangen" />
    <bpmn:sequenceFlow id="Flow_Bescheid_Ende_Buerger" sourceRef="Event_Bescheid_empfangen" targetRef="EndEvent_Buerger" />
  </bpmn:process>

  <bpmn:process id="Process_IT" name="Stuttgarter_Sportfoerderung_beantragen_IT" isExecutable="true">
    <bpmn:startEvent id="StartEvent_IT_Antrag_eingegangen" name="Antrag eingegangen">
      <bpmn:outgoing>Flow_IT_Start_Erfassen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Antrag_erfassen" name="Antrag erfassen">
      <bpmn:incoming>Flow_IT_Start_Erfassen</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Erfassen_Pruefen</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Unterlagen_pruefen" name="Unterlagen pruefen">
      <bpmn:incoming>Flow_IT_Erfassen_Pruefen</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Pruefen_Uebermitteln</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Antragsdaten_uebermitteln" name="Antragsdaten uebermitteln">
      <bpmn:incoming>Flow_IT_Pruefen_Uebermitteln</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Uebermitteln_Warten</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:intermediateCatchEvent id="Event_Bescheid_eingegangen" name="Bescheid eingegangen">
      <bpmn:incoming>Flow_IT_Uebermitteln_Warten</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Bescheid_Bereitstellen</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDef_Bescheid_IT" messageRef="Message_Foerderbescheid" />
    </bpmn:intermediateCatchEvent>
    <bpmn:serviceTask id="Task_Bescheid_bereitstellen" name="Bescheid bereitstellen">
      <bpmn:incoming>Flow_IT_Bescheid_Bereitstellen</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Bereitstellen_Ende</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_IT" name="Bescheid bereitgestellt">
      <bpmn:incoming>Flow_IT_Bereitstellen_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_IT_Start_Erfassen" sourceRef="StartEvent_IT_Antrag_eingegangen" targetRef="Task_Antrag_erfassen" />
    <bpmn:sequenceFlow id="Flow_IT_Erfassen_Pruefen" sourceRef="Task_Antrag_erfassen" targetRef="Task_Unterlagen_pruefen" />
    <bpmn:sequenceFlow id="Flow_IT_Pruefen_Uebermitteln" sourceRef="Task_Unterlagen_pruefen" targetRef="Task_Antragsdaten_uebermitteln" />
    <bpmn:sequenceFlow id="Flow_IT_Uebermitteln_Warten" sourceRef="Task_Antragsdaten_uebermitteln" targetRef="Event_Bescheid_eingegangen" />
    <bpmn:sequenceFlow id="Flow_IT_Bescheid_Bereitstellen" sourceRef="Event_Bescheid_eingegangen" targetRef="Task_Bescheid_bereitstellen" />
    <bpmn:sequenceFlow id="Flow_IT_Bereitstellen_Ende" sourceRef="Task_Bescheid_bereitstellen" targetRef="EndEvent_IT" />
  </bpmn:process>

  <bpmn:process id="Process_Behoerde" name="Stuttgarter_Sportfoerderung_beantragen_Behoerde" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Behoerde_Antrag_eingegangen" name="Antragsdaten eingegangen">
      <bpmn:outgoing>Flow_Behoerde_Start_Zustaendigkeit</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Zustaendigkeit_pruefen" name="Zustaendigkeit pruefen">
      <bpmn:incoming>Flow_Behoerde_Start_Zustaendigkeit</bpmn:incoming>
      <bpmn:outgoing>Flow_Zustaendigkeit_Foerderfaehigkeit</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Foerderfaehigkeit_bewerten" name="Foerderfaehigkeit bewerten">
      <bpmn:incoming>Flow_Zustaendigkeit_Foerderfaehigkeit</bpmn:incoming>
      <bpmn:outgoing>Flow_Foerderfaehigkeit_Betrag</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Foerderbetrag_festlegen" name="Foerderbetrag festlegen">
      <bpmn:incoming>Flow_Foerderfaehigkeit_Betrag</bpmn:incoming>
      <bpmn:outgoing>Flow_Betrag_Bescheid</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Bescheid_erstellen" name="Bescheid erstellen">
      <bpmn:incoming>Flow_Betrag_Bescheid</bpmn:incoming>
      <bpmn:outgoing>Flow_Bescheid_Ende_Behoerde</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Behoerde" name="Antrag bearbeitet">
      <bpmn:incoming>Flow_Bescheid_Ende_Behoerde</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Behoerde_Start_Zustaendigkeit" sourceRef="StartEvent_Behoerde_Antrag_eingegangen" targetRef="Task_Zustaendigkeit_pruefen" />
    <bpmn:sequenceFlow id="Flow_Zustaendigkeit_Foerderfaehigkeit" sourceRef="Task_Zustaendigkeit_pruefen" targetRef="Task_Foerderfaehigkeit_bewerten" />
    <bpmn:sequenceFlow id="Flow_Foerderfaehigkeit_Betrag" sourceRef="Task_Foerderfaehigkeit_bewerten" targetRef="Task_Foerderbetrag_festlegen" />
    <bpmn:sequenceFlow id="Flow_Betrag_Bescheid" sourceRef="Task_Foerderbetrag_festlegen" targetRef="Task_Bescheid_erstellen" />
    <bpmn:sequenceFlow id="Flow_Bescheid_Ende_Behoerde" sourceRef="Task_Bescheid_erstellen" targetRef="EndEvent_Behoerde" />
  </bpmn:process>

