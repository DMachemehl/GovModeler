      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Ablehnungsbescheid_Frist_erstellen_di" bpmnElement="Task_Ablehnungsbescheid_Frist_erstellen">
        <dc:Bounds x="990" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Ablehnungsbescheid_Frist_versenden_di" bpmnElement="Task_Ablehnungsbescheid_Frist_versenden">
        <dc:Bounds x="1150" y="380" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Ablehnung_Frist_di" bpmnElement="EndEvent_Ablehnung_Frist">
        <dc:Bounds x="1312" y="402" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1292" y="445" width="76" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Anlegen_Vollstaendigkeit_di" bpmnElement="Flow_Anlegen_Vollstaendigkeit">
        <di:waypoint x="410" y="520" />
        <di:waypoint x="470" y="520" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Vollstaendigkeit_Gateway_di" bpmnElement="Flow_Vollstaendigkeit_Gateway">
