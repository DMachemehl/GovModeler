      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Participant_Sachbearbeiter_di" bpmnElement="Participant_Sachbearbeiter" isHorizontal="true">
        <dc:Bounds x="160" y="340" width="2800" height="400" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_Sachbearbeiter_di" bpmnElement="Lane_Sachbearbeiter" isHorizontal="true">
        <dc:Bounds x="190" y="340" width="2770" height="400" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Vorgang_anlegen_di" bpmnElement="Task_Vorgang_anlegen">
        <dc:Bounds x="310" y="480" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Vollstaendigkeit_pruefen_di" bpmnElement="Task_Vollstaendigkeit_pruefen">
        <dc:Bounds x="470" y="480" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Vollstaendigkeit_di" bpmnElement="Gateway_Vollstaendigkeit" isMarkerVisible="true">
        <dc:Bounds x="635" y="495" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="625" y="552" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
