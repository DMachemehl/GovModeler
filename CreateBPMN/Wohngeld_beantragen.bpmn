        <dc:Bounds x="1030" y="650" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Auszahlung_anstossen_di" bpmnElement="Task_Auszahlung_anstossen">
        <dc:Bounds x="1190" y="650" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Bewilligungsbescheid_versenden_di" bpmnElement="Task_Bewilligungsbescheid_versenden">
        <dc:Bounds x="1350" y="650" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Bewilligung_di" bpmnElement="EndEvent_Bewilligung">
        <dc:Bounds x="1512" y="672" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1496" y="715" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Ablehnungsbescheid_erstellen_di" bpmnElement="Task_Ablehnungsbescheid_erstellen">
        <dc:Bounds x="1030" y="530" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Ablehnungsbescheid_versenden_di" bpmnElement="Task_Ablehnungsbescheid_versenden">
        <dc:Bounds x="1190" y="530" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Ablehnung_di" bpmnElement="EndEvent_Ablehnung">
