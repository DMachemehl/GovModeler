        <dc:Bounds x="310" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Antrag_weiterleiten_di" bpmnElement="Task_Antrag_weiterleiten">
        <dc:Bounds x="470" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Poststelle_di" bpmnElement="EndEvent_Poststelle">
