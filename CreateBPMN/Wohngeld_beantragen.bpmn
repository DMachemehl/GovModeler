        <dc:Bounds x="775" y="395" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Unterlagen_eingegangen_di" bpmnElement="Event_Unterlagen_eingegangen">
        <dc:Bounds x="782" y="502" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="766" y="545" width="68" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Frist_abgelaufen_di" bpmnElement="Event_Frist_abgelaufen">
        <dc:Bounds x="892" y="402" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="878" y="378" width="64" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Inhaltliche_Pruefung_di" bpmnElement="Task_Inhaltliche_Pruefung">
        <dc:Bounds x="750" y="580" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Anspruch_di" bpmnElement="Gateway_Anspruch" isMarkerVisible="true">
        <dc:Bounds x="915" y="595" width="50" height="50" />
