<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://example.com/bpmn" exporter="GitHub-Copilot-GovModeler" exporterVersion="2.0" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" modeler:executionPlatform="Camunda Platform" modeler:executionPlatformVersion="7.24.0">
  <bpmn:collaboration id="Collab_Wohngeld_beantragen">
    <bpmn:participant id="Participant_Poststelle" name="Poststelle" processRef="Process_Poststelle" />
    <bpmn:participant id="Participant_Sachbearbeiter" name="Sachbearbeiter Wohngeld" processRef="Process_Sachbearbeiter" />
    <bpmn:messageFlow id="MsgFlow_Antrag_Weiterleitung" name="Antrag per Hauspost" sourceRef="Task_Antrag_weiterleiten" targetRef="Task_Vorgang_anlegen" />
    <bpmn:messageFlow id="MsgFlow_Unterlagen_Eingang" name="Nachgeforderte Unterlagen" sourceRef="Task_Antrag_weiterleiten" targetRef="Event_Unterlagen_eingegangen" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Poststelle" name="Wohngeld_Poststelle" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Antrag" name="Antrag eingegangen">
      <bpmn:outgoing>Flow_Start_Zustaendigkeit</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Zustaendigkeit_pruefen" name="Zustaendigkeit pruefen">
      <bpmn:incoming>Flow_Start_Zustaendigkeit</bpmn:incoming>
      <bpmn:outgoing>Flow_Zustaendigkeit_Weiterleiten</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="Task_Antrag_weiterleiten" name="Antrag per Hauspost weiterleiten">
      <bpmn:incoming>Flow_Zustaendigkeit_Weiterleiten</bpmn:incoming>
      <bpmn:outgoing>Flow_Weiterleiten_Ende</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="EndEvent_Poststelle" name="Weitergeleitet">
      <bpmn:incoming>Flow_Weiterleiten_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Zustaendigkeit" sourceRef="StartEvent_Antrag" targetRef="Task_Zustaendigkeit_pruefen" />
    <bpmn:sequenceFlow id="Flow_Zustaendigkeit_Weiterleiten" sourceRef="Task_Zustaendigkeit_pruefen" targetRef="Task_Antrag_weiterleiten" />
    <bpmn:sequenceFlow id="Flow_Weiterleiten_Ende" sourceRef="Task_Antrag_weiterleiten" targetRef="EndEvent_Poststelle" />
  </bpmn:process>
  <bpmn:process id="Process_Sachbearbeiter" name="Wohngeld_Sachbearbeiter" isExecutable="true">
    <bpmn:laneSet id="LaneSet_Sachbearbeiter">
      <bpmn:lane id="Lane_Sachbearbeiter" name="Sachbearbeiter Wohngeld">
        <bpmn:flowNodeRef>Task_Vorgang_anlegen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Vollstaendigkeit_pruefen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Vollstaendigkeit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Nachforderung_versenden</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_Unterlagen_eingegangen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Frist</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Inhaltliche_Pruefung</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_Anspruch</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Bewilligungsbescheid_erstellen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Auszahlung_anstossen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Bewilligungsbescheid_versenden</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Bewilligung</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Ablehnungsbescheid_erstellen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Ablehnungsbescheid_versenden</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Ablehnung</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Ablehnungsbescheid_Frist_erstellen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_Ablehnungsbescheid_Frist_versenden</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_Ablehnung_Frist</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:userTask id="Task_Vorgang_anlegen" name="Vorgang in Wohni anlegen">
      <bpmn:outgoing>Flow_Anlegen_Vollstaendigkeit</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Vollstaendigkeit_pruefen" name="Vollstaendigkeit pruefen">
      <bpmn:documentation>Prüfung: Formularfelder ausgefüllt, erforderliche Unterlagen beigefügt, Unterschriften vorhanden</bpmn:documentation>
      <bpmn:incoming>Flow_Anlegen_Vollstaendigkeit</bpmn:incoming>
      <bpmn:incoming>Flow_Unterlagen_erneut_pruefen</bpmn:incoming>
      <bpmn:outgoing>Flow_Vollstaendigkeit_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Vollstaendigkeit" name="Vollstaendig?">
      <bpmn:incoming>Flow_Vollstaendigkeit_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Vollstaendig_Ja</bpmn:outgoing>
      <bpmn:outgoing>Flow_Vollstaendig_Nein</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Nachforderung_versenden" name="Unterlagen per Brief nachfordern">
      <bpmn:documentation>Frist: 14 Tage</bpmn:documentation>
      <bpmn:incoming>Flow_Vollstaendig_Nein</bpmn:incoming>
      <bpmn:outgoing>Flow_Nachforderung_Warten</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:eventBasedGateway id="Gateway_Frist" name="">
      <bpmn:incoming>Flow_Nachforderung_Warten</bpmn:incoming>
      <bpmn:outgoing>Flow_Frist_Unterlagen</bpmn:outgoing>
      <bpmn:outgoing>Flow_Frist_Ablauf</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Event_Unterlagen_eingegangen" name="Unterlagen eingegangen">
      <bpmn:incoming>Flow_Frist_Unterlagen</bpmn:incoming>
      <bpmn:outgoing>Flow_Unterlagen_erneut_pruefen</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDef_Unterlagen" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Event_Frist_abgelaufen" name="14 Tage abgelaufen">
      <bpmn:incoming>Flow_Frist_Ablauf</bpmn:incoming>
      <bpmn:outgoing>Flow_Frist_Ablehnung</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDef_Frist">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">P14D</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="Task_Inhaltliche_Pruefung" name="Inhaltliche Pruefung durchfuehren">
      <bpmn:documentation>Prüfung: Anspruchsvoraussetzungen, Einkommensgrenzen, Wohnkosten. Automatische Berechnung der Wohngeldhöhe im Fachverfahren.</bpmn:documentation>
      <bpmn:incoming>Flow_Vollstaendig_Ja</bpmn:incoming>
      <bpmn:outgoing>Flow_Pruefung_Gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Anspruch" name="Anspruch?">
      <bpmn:incoming>Flow_Pruefung_Gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_Anspruch_Ja</bpmn:outgoing>
      <bpmn:outgoing>Flow_Anspruch_Nein</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_Bewilligungsbescheid_erstellen" name="Bewilligungsbescheid erstellen">
      <bpmn:documentation>Erstellung im Fachverfahren Wohni mit Bescheidvorlage</bpmn:documentation>
      <bpmn:incoming>Flow_Anspruch_Ja</bpmn:incoming>
      <bpmn:outgoing>Flow_Bewilligung_Auszahlung</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Auszahlung_anstossen" name="Auszahlung in Wohni anstossen">
      <bpmn:incoming>Flow_Bewilligung_Auszahlung</bpmn:incoming>
      <bpmn:outgoing>Flow_Auszahlung_Versand</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="Task_Bewilligungsbescheid_versenden" name="Bescheid ueber zentralen Druck versenden">
      <bpmn:incoming>Flow_Auszahlung_Versand</bpmn:incoming>
      <bpmn:outgoing>Flow_Bewilligung_Ende</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="EndEvent_Bewilligung" name="Wohngeld bewilligt">
      <bpmn:incoming>Flow_Bewilligung_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_Ablehnungsbescheid_erstellen" name="Ablehnungsbescheid erstellen">
      <bpmn:documentation>Erstellung im Fachverfahren Wohni mit Vorlage</bpmn:documentation>
      <bpmn:incoming>Flow_Anspruch_Nein</bpmn:incoming>
      <bpmn:outgoing>Flow_Ablehnung_Versand</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="Task_Ablehnungsbescheid_versenden" name="Bescheid ueber zentralen Druck versenden">
      <bpmn:incoming>Flow_Ablehnung_Versand</bpmn:incoming>
      <bpmn:outgoing>Flow_Ablehnung_Ende</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="EndEvent_Ablehnung" name="Antrag abgelehnt">
      <bpmn:incoming>Flow_Ablehnung_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="Task_Ablehnungsbescheid_Frist_erstellen" name="Ablehnungsbescheid erstellen">
      <bpmn:documentation>Erstellung im Fachverfahren Wohni mit Vorlage - Ablehnung wegen fehlender Unterlagen</bpmn:documentation>
      <bpmn:incoming>Flow_Frist_Ablehnung</bpmn:incoming>
      <bpmn:outgoing>Flow_Frist_Ablehnung_Versand</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sendTask id="Task_Ablehnungsbescheid_Frist_versenden" name="Bescheid ueber zentralen Druck versenden">
      <bpmn:incoming>Flow_Frist_Ablehnung_Versand</bpmn:incoming>
      <bpmn:outgoing>Flow_Frist_Ablehnung_Ende</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="EndEvent_Ablehnung_Frist" name="Antrag abgelehnt">
      <bpmn:incoming>Flow_Frist_Ablehnung_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Anlegen_Vollstaendigkeit" sourceRef="Task_Vorgang_anlegen" targetRef="Task_Vollstaendigkeit_pruefen" />
    <bpmn:sequenceFlow id="Flow_Vollstaendigkeit_Gateway" sourceRef="Task_Vollstaendigkeit_pruefen" targetRef="Gateway_Vollstaendigkeit" />
    <bpmn:sequenceFlow id="Flow_Vollstaendig_Ja" name="Ja" sourceRef="Gateway_Vollstaendigkeit" targetRef="Task_Inhaltliche_Pruefung" />
    <bpmn:sequenceFlow id="Flow_Vollstaendig_Nein" name="Nein" sourceRef="Gateway_Vollstaendigkeit" targetRef="Task_Nachforderung_versenden" />
    <bpmn:sequenceFlow id="Flow_Nachforderung_Warten" sourceRef="Task_Nachforderung_versenden" targetRef="Gateway_Frist" />
    <bpmn:sequenceFlow id="Flow_Frist_Unterlagen" sourceRef="Gateway_Frist" targetRef="Event_Unterlagen_eingegangen" />
    <bpmn:sequenceFlow id="Flow_Frist_Ablauf" sourceRef="Gateway_Frist" targetRef="Event_Frist_abgelaufen" />
    <bpmn:sequenceFlow id="Flow_Unterlagen_erneut_pruefen" sourceRef="Event_Unterlagen_eingegangen" targetRef="Task_Vollstaendigkeit_pruefen" />
    <bpmn:sequenceFlow id="Flow_Frist_Ablehnung" sourceRef="Event_Frist_abgelaufen" targetRef="Task_Ablehnungsbescheid_Frist_erstellen" />
    <bpmn:sequenceFlow id="Flow_Pruefung_Gateway" sourceRef="Task_Inhaltliche_Pruefung" targetRef="Gateway_Anspruch" />
    <bpmn:sequenceFlow id="Flow_Anspruch_Ja" name="Ja" sourceRef="Gateway_Anspruch" targetRef="Task_Bewilligungsbescheid_erstellen" />
    <bpmn:sequenceFlow id="Flow_Anspruch_Nein" name="Nein" sourceRef="Gateway_Anspruch" targetRef="Task_Ablehnungsbescheid_erstellen" />
    <bpmn:sequenceFlow id="Flow_Bewilligung_Auszahlung" sourceRef="Task_Bewilligungsbescheid_erstellen" targetRef="Task_Auszahlung_anstossen" />
    <bpmn:sequenceFlow id="Flow_Auszahlung_Versand" sourceRef="Task_Auszahlung_anstossen" targetRef="Task_Bewilligungsbescheid_versenden" />
    <bpmn:sequenceFlow id="Flow_Bewilligung_Ende" sourceRef="Task_Bewilligungsbescheid_versenden" targetRef="EndEvent_Bewilligung" />
    <bpmn:sequenceFlow id="Flow_Ablehnung_Versand" sourceRef="Task_Ablehnungsbescheid_erstellen" targetRef="Task_Ablehnungsbescheid_versenden" />
    <bpmn:sequenceFlow id="Flow_Ablehnung_Ende" sourceRef="Task_Ablehnungsbescheid_versenden" targetRef="EndEvent_Ablehnung" />
    <bpmn:sequenceFlow id="Flow_Frist_Ablehnung_Versand" sourceRef="Task_Ablehnungsbescheid_Frist_erstellen" targetRef="Task_Ablehnungsbescheid_Frist_versenden" />
    <bpmn:sequenceFlow id="Flow_Frist_Ablehnung_Ende" sourceRef="Task_Ablehnungsbescheid_Frist_versenden" targetRef="EndEvent_Ablehnung_Frist" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Wohngeld">
    <bpmndi:BPMNPlane id="BPMNPlane_Wohngeld" bpmnElement="Collab_Wohngeld_beantragen">
      <bpmndi:BPMNShape id="Participant_Poststelle_di" bpmnElement="Participant_Poststelle" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="800" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Antrag_di" bpmnElement="StartEvent_Antrag">
        <dc:Bounds x="222" y="162" width="36" height="36" />
