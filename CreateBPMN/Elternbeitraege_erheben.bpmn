<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  targetNamespace="http://example.com/bpmn"
  exporter="GitHub-Copilot-GovModeler"
  exporterVersion="2.0">

  <!-- =====================================================
       COLLABORATION
       ===================================================== -->
  <bpmn:collaboration id="Collab_Elternbeitraege_erheben">

    <bpmn:participant id="Participant_Buerger"
                      name="Buerger (Eltern)"
                      processRef="Process_Buerger" />

    <bpmn:participant id="Participant_IT"
                      name="IT"
                      processRef="Process_IT" />

    <bpmn:participant id="Participant_Behoerde"
                      name="Jugendamt"
                      processRef="Process_Behoerde" />

    <!-- Message Flows -->
    <bpmn:messageFlow id="MsgFlow_Unterlagen_anfordern"
                      name="Unterlagen anfordern"
                      sourceRef="Task_Unterlagen_anfordern"
                      targetRef="StartEvent_Buerger" />

    <bpmn:messageFlow id="MsgFlow_Einkommensnachweise_einreichen"
                      name="Einkommensnachweise"
                      sourceRef="Task_Einkommensnachweise_einreichen"
                      targetRef="Event_Nachweise_eingegangen" />

    <bpmn:messageFlow id="MsgFlow_IT_Anfrage"
                      name="Einkommensdaten pruefen"
                      sourceRef="Task_Beitrag_berechnen_anstoessen"
                      targetRef="StartEvent_IT" />

    <bpmn:messageFlow id="MsgFlow_IT_Ergebnis"
                      name="Berechnungsergebnis"
                      sourceRef="Task_IT_Ergebnis_senden"
                      targetRef="Event_Berechnungsergebnis_erhalten" />

    <bpmn:messageFlow id="MsgFlow_Beitragsbescheid"
                      name="Beitragsbescheid"
                      sourceRef="Task_Beitragsbescheid_versenden"
                      targetRef="Event_Bescheid_erhalten" />

  </bpmn:collaboration>

  <!-- =====================================================
       BUERGER PROZESS
       ===================================================== -->
  <bpmn:process id="Process_Buerger" name="Elternbeitraege_erheben_Buerger" isExecutable="true">

    <bpmn:startEvent id="StartEvent_Buerger" name="Unterlagen angefordert">
      <bpmn:outgoing>Flow_Buerger_Start_Einreichen</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Buerger_Start" />
    </bpmn:startEvent>

    <bpmn:userTask id="Task_Einkommensnachweise_einreichen" name="Einkommensnachweise einreichen">
      <bpmn:incoming>Flow_Buerger_Start_Einreichen</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Einreichen_Warten</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:intermediateCatchEvent id="Event_Bescheid_erhalten" name="Beitragsbescheid erhalten">
      <bpmn:incoming>Flow_Buerger_Einreichen_Warten</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Bescheid_Zahlen</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Bescheid_erhalten" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="Task_Elternbeitrag_entrichten" name="Elternbeitrag entrichten">
      <bpmn:incoming>Flow_Buerger_Bescheid_Zahlen</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Zahlen_Ende</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_Buerger" name="Elternbeitrag entrichtet">
      <bpmn:incoming>Flow_Buerger_Zahlen_Ende</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Buerger_Start_Einreichen"
                       sourceRef="StartEvent_Buerger"
                       targetRef="Task_Einkommensnachweise_einreichen" />
    <bpmn:sequenceFlow id="Flow_Buerger_Einreichen_Warten"
                       sourceRef="Task_Einkommensnachweise_einreichen"
                       targetRef="Event_Bescheid_erhalten" />
    <bpmn:sequenceFlow id="Flow_Buerger_Bescheid_Zahlen"
                       sourceRef="Event_Bescheid_erhalten"
                       targetRef="Task_Elternbeitrag_entrichten" />
    <bpmn:sequenceFlow id="Flow_Buerger_Zahlen_Ende"
                       sourceRef="Task_Elternbeitrag_entrichten"
                       targetRef="EndEvent_Buerger" />
  </bpmn:process>

  <!-- =====================================================
       IT PROZESS
       ===================================================== -->
  <bpmn:process id="Process_IT" name="Elternbeitraege_erheben_IT" isExecutable="true">

    <bpmn:startEvent id="StartEvent_IT" name="Pruefanfrage erhalten">
      <bpmn:outgoing>Flow_IT_Start_Pruefen</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_IT_Start" />
    </bpmn:startEvent>

    <bpmn:serviceTask id="Task_IT_Einkommensdaten_pruefen" name="Einkommensdaten pruefen">
      <bpmn:incoming>Flow_IT_Start_Pruefen</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Pruefen_Berechnen</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_IT_Elternbeitrag_berechnen" name="Elternbeitrag berechnen">
      <bpmn:incoming>Flow_IT_Pruefen_Berechnen</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Berechnen_Generieren</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_IT_Bescheid_generieren" name="Beitragsbescheid generieren">
      <bpmn:incoming>Flow_IT_Berechnen_Generieren</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Generieren_Senden</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:serviceTask id="Task_IT_Ergebnis_senden" name="Ergebnis senden">
      <bpmn:incoming>Flow_IT_Generieren_Senden</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Senden_Ende</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_IT" name="Berechnung abgeschlossen">
      <bpmn:incoming>Flow_IT_Senden_Ende</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_IT_Start_Pruefen"
                       sourceRef="StartEvent_IT"
                       targetRef="Task_IT_Einkommensdaten_pruefen" />
    <bpmn:sequenceFlow id="Flow_IT_Pruefen_Berechnen"
                       sourceRef="Task_IT_Einkommensdaten_pruefen"
                       targetRef="Task_IT_Elternbeitrag_berechnen" />
    <bpmn:sequenceFlow id="Flow_IT_Berechnen_Generieren"
                       sourceRef="Task_IT_Elternbeitrag_berechnen"
                       targetRef="Task_IT_Bescheid_generieren" />
    <bpmn:sequenceFlow id="Flow_IT_Generieren_Senden"
                       sourceRef="Task_IT_Bescheid_generieren"
                       targetRef="Task_IT_Ergebnis_senden" />
    <bpmn:sequenceFlow id="Flow_IT_Senden_Ende"
                       sourceRef="Task_IT_Ergebnis_senden"
                       targetRef="EndEvent_IT" />
  </bpmn:process>

  <!-- =====================================================
       BEHOERDE PROZESS (Jugendamt)
       ===================================================== -->
  <bpmn:process id="Process_Behoerde" name="Elternbeitraege_erheben_Behoerde" isExecutable="true">

    <bpmn:startEvent id="StartEvent_Behoerde" name="Betreuungsverhaeltnis besteht">
      <bpmn:outgoing>Flow_Behoerde_Start_Anfordern</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_Unterlagen_anfordern" name="Unterlagen anfordern">
      <bpmn:incoming>Flow_Behoerde_Start_Anfordern</bpmn:incoming>
      <bpmn:outgoing>Flow_Behoerde_Anfordern_Warten</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:intermediateCatchEvent id="Event_Nachweise_eingegangen" name="Nachweise eingegangen">
      <bpmn:incoming>Flow_Behoerde_Anfordern_Warten</bpmn:incoming>
      <bpmn:outgoing>Flow_Behoerde_Nachweise_Berechnen</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Nachweise_eingegangen" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="Task_Beitrag_berechnen_anstoessen" name="Beitragsberechnung anstoessen">
      <bpmn:incoming>Flow_Behoerde_Nachweise_Berechnen</bpmn:incoming>
      <bpmn:outgoing>Flow_Behoerde_Berechnen_Warten</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:intermediateCatchEvent id="Event_Berechnungsergebnis_erhalten" name="Berechnungsergebnis erhalten">
      <bpmn:incoming>Flow_Behoerde_Berechnen_Warten</bpmn:incoming>
      <bpmn:outgoing>Flow_Behoerde_Ergebnis_Festsetzen</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_Berechnungsergebnis" />
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="Task_Beitrag_festsetzen" name="Beitrag festsetzen">
      <bpmn:incoming>Flow_Behoerde_Ergebnis_Festsetzen</bpmn:incoming>
      <bpmn:outgoing>Flow_Behoerde_Festsetzen_Versenden</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_Beitragsbescheid_versenden" name="Beitragsbescheid versenden">
      <bpmn:incoming>Flow_Behoerde_Festsetzen_Versenden</bpmn:incoming>
      <bpmn:outgoing>Flow_Behoerde_Versenden_Ende</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_Behoerde" name="Elternbeitrag erhoben">
      <bpmn:incoming>Flow_Behoerde_Versenden_Ende</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_Behoerde_Start_Anfordern"
                       sourceRef="StartEvent_Behoerde"
                       targetRef="Task_Unterlagen_anfordern" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Anfordern_Warten"
                       sourceRef="Task_Unterlagen_anfordern"
                       targetRef="Event_Nachweise_eingegangen" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Nachweise_Berechnen"
                       sourceRef="Event_Nachweise_eingegangen"
                       targetRef="Task_Beitrag_berechnen_anstoessen" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Berechnen_Warten"
                       sourceRef="Task_Beitrag_berechnen_anstoessen"
                       targetRef="Event_Berechnungsergebnis_erhalten" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Ergebnis_Festsetzen"
                       sourceRef="Event_Berechnungsergebnis_erhalten"
                       targetRef="Task_Beitrag_festsetzen" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Festsetzen_Versenden"
                       sourceRef="Task_Beitrag_festsetzen"
                       targetRef="Task_Beitragsbescheid_versenden" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Versenden_Ende"
                       sourceRef="Task_Beitragsbescheid_versenden"
                       targetRef="EndEvent_Behoerde" />
  </bpmn:process>

  <!-- =====================================================
       BPMN-DI VISUALISIERUNG
       ===================================================== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_Elternbeitraege_erheben">
    <bpmndi:BPMNPlane id="BPMNPlane_Elternbeitraege_erheben" bpmnElement="Collab_Elternbeitraege_erheben">

      <!-- ===============================
           POOL: BUERGER (y=80, Hoehe=250)
           =============================== -->
      <bpmndi:BPMNShape id="Participant_Buerger_di" bpmnElement="Participant_Buerger" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1200" height="250" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="170" y="190" width="20" height="70" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Buerger: StartEvent x=222, y=182 -->
      <bpmndi:BPMNShape id="StartEvent_Buerger_di" bpmnElement="StartEvent_Buerger">
        <dc:Bounds x="222" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="198" y="225" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Buerger: Task 1 x=310, y=160 -->
      <bpmndi:BPMNShape id="Task_Einkommensnachweise_einreichen_di" bpmnElement="Task_Einkommensnachweise_einreichen">
        <dc:Bounds x="310" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Buerger: IntermediateCatchEvent x=470, y=182 -->
      <bpmndi:BPMNShape id="Event_Bescheid_erhalten_di" bpmnElement="Event_Bescheid_erhalten">
        <dc:Bounds x="470" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="448" y="225" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Buerger: Task 2 x=560, y=160 -->
      <bpmndi:BPMNShape id="Task_Elternbeitrag_entrichten_di" bpmnElement="Task_Elternbeitrag_entrichten">
        <dc:Bounds x="560" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Buerger: EndEvent x=720, y=182 -->
      <bpmndi:BPMNShape id="EndEvent_Buerger_di" bpmnElement="EndEvent_Buerger">
        <dc:Bounds x="720" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="698" y="225" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Buerger Sequence Flows -->
      <bpmndi:BPMNEdge id="Flow_Buerger_Start_Einreichen_di" bpmnElement="Flow_Buerger_Start_Einreichen">
        <di:waypoint x="258" y="200" />
        <di:waypoint x="310" y="200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Buerger_Einreichen_Warten_di" bpmnElement="Flow_Buerger_Einreichen_Warten">
        <di:waypoint x="410" y="200" />
        <di:waypoint x="470" y="200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Buerger_Bescheid_Zahlen_di" bpmnElement="Flow_Buerger_Bescheid_Zahlen">
        <di:waypoint x="506" y="200" />
        <di:waypoint x="560" y="200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Buerger_Zahlen_Ende_di" bpmnElement="Flow_Buerger_Zahlen_Ende">
        <di:waypoint x="660" y="200" />
        <di:waypoint x="720" y="200" />
      </bpmndi:BPMNEdge>

      <!-- ===============================
           POOL: IT (y=370, Hoehe=250)
           =============================== -->
      <bpmndi:BPMNShape id="Participant_IT_di" bpmnElement="Participant_IT" isHorizontal="true">
        <dc:Bounds x="160" y="370" width="1200" height="250" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="170" y="480" width="20" height="30" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- IT: StartEvent x=222, y=477 -->
      <bpmndi:BPMNShape id="StartEvent_IT_di" bpmnElement="StartEvent_IT">
        <dc:Bounds x="222" y="477" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="198" y="520" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- IT: Task 1 x=310, y=455 -->
      <bpmndi:BPMNShape id="Task_IT_Einkommensdaten_pruefen_di" bpmnElement="Task_IT_Einkommensdaten_pruefen">
        <dc:Bounds x="310" y="455" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- IT: Task 2 x=470, y=455 -->
      <bpmndi:BPMNShape id="Task_IT_Elternbeitrag_berechnen_di" bpmnElement="Task_IT_Elternbeitrag_berechnen">
        <dc:Bounds x="470" y="455" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- IT: Task 3 x=630, y=455 -->
      <bpmndi:BPMNShape id="Task_IT_Bescheid_generieren_di" bpmnElement="Task_IT_Bescheid_generieren">
        <dc:Bounds x="630" y="455" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- IT: Task 4 x=790, y=455 -->
      <bpmndi:BPMNShape id="Task_IT_Ergebnis_senden_di" bpmnElement="Task_IT_Ergebnis_senden">
        <dc:Bounds x="790" y="455" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- IT: EndEvent x=952, y=477 -->
      <bpmndi:BPMNShape id="EndEvent_IT_di" bpmnElement="EndEvent_IT">
        <dc:Bounds x="952" y="477" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="928" y="520" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- IT Sequence Flows -->
      <bpmndi:BPMNEdge id="Flow_IT_Start_Pruefen_di" bpmnElement="Flow_IT_Start_Pruefen">
        <di:waypoint x="258" y="495" />
        <di:waypoint x="310" y="495" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_IT_Pruefen_Berechnen_di" bpmnElement="Flow_IT_Pruefen_Berechnen">
        <di:waypoint x="410" y="495" />
        <di:waypoint x="470" y="495" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_IT_Berechnen_Generieren_di" bpmnElement="Flow_IT_Berechnen_Generieren">
        <di:waypoint x="570" y="495" />
        <di:waypoint x="630" y="495" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_IT_Generieren_Senden_di" bpmnElement="Flow_IT_Generieren_Senden">
        <di:waypoint x="730" y="495" />
        <di:waypoint x="790" y="495" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_IT_Senden_Ende_di" bpmnElement="Flow_IT_Senden_Ende">
        <di:waypoint x="890" y="495" />
        <di:waypoint x="952" y="495" />
      </bpmndi:BPMNEdge>

      <!-- ===============================
           POOL: BEHOERDE (y=660, Hoehe=250)
           =============================== -->
      <bpmndi:BPMNShape id="Participant_Behoerde_di" bpmnElement="Participant_Behoerde" isHorizontal="true">
        <dc:Bounds x="160" y="660" width="1200" height="250" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="170" y="770" width="20" height="60" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Behoerde: StartEvent x=222, y=782 -->
      <bpmndi:BPMNShape id="StartEvent_Behoerde_di" bpmnElement="StartEvent_Behoerde">
        <dc:Bounds x="222" y="782" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="196" y="825" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Behoerde: Task 1 x=310, y=760 -->
      <bpmndi:BPMNShape id="Task_Unterlagen_anfordern_di" bpmnElement="Task_Unterlagen_anfordern">
        <dc:Bounds x="310" y="760" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Behoerde: IntermediateCatchEvent x=470, y=782 -->
      <bpmndi:BPMNShape id="Event_Nachweise_eingegangen_di" bpmnElement="Event_Nachweise_eingegangen">
        <dc:Bounds x="470" y="782" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="448" y="825" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Behoerde: Task 2 x=560, y=760 -->
      <bpmndi:BPMNShape id="Task_Beitrag_berechnen_anstoessen_di" bpmnElement="Task_Beitrag_berechnen_anstoessen">
        <dc:Bounds x="560" y="760" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Behoerde: IntermediateCatchEvent x=720, y=782 -->
      <bpmndi:BPMNShape id="Event_Berechnungsergebnis_erhalten_di" bpmnElement="Event_Berechnungsergebnis_erhalten">
        <dc:Bounds x="720" y="782" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="695" y="825" width="86" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Behoerde: Task 3 x=810, y=760 -->
      <bpmndi:BPMNShape id="Task_Beitrag_festsetzen_di" bpmnElement="Task_Beitrag_festsetzen">
        <dc:Bounds x="810" y="760" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Behoerde: Task 4 x=970, y=760 -->
      <bpmndi:BPMNShape id="Task_Beitragsbescheid_versenden_di" bpmnElement="Task_Beitragsbescheid_versenden">
        <dc:Bounds x="970" y="760" width="100" height="80" />
      </bpmndi:BPMNShape>

      <!-- Behoerde: EndEvent x=1130, y=782 -->
      <bpmndi:BPMNShape id="EndEvent_Behoerde_di" bpmnElement="EndEvent_Behoerde">
        <dc:Bounds x="1130" y="782" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1108" y="825" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Behoerde Sequence Flows -->
      <bpmndi:BPMNEdge id="Flow_Behoerde_Start_Anfordern_di" bpmnElement="Flow_Behoerde_Start_Anfordern">
        <di:waypoint x="258" y="800" />
        <di:waypoint x="310" y="800" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Behoerde_Anfordern_Warten_di" bpmnElement="Flow_Behoerde_Anfordern_Warten">
        <di:waypoint x="410" y="800" />
        <di:waypoint x="470" y="800" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Behoerde_Nachweise_Berechnen_di" bpmnElement="Flow_Behoerde_Nachweise_Berechnen">
        <di:waypoint x="506" y="800" />
        <di:waypoint x="560" y="800" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_Behoerde_Berechnen_Warten_di" bpmnElement="Flow_Behoerde_Berechnen_Warten">
        <di:waypoint x="660" y="800" />
        <di:waypoint x="720" y="800" />
      </bpmndi:BPMNEdge>

