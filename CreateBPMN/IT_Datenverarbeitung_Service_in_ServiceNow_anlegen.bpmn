      <bpmndi:BPMNShape id="Task_Benachrichtigungsinhalt_generieren_di" bpmnElement="Task_Benachrichtigungsinhalt_generieren">
        <dc:Bounds x="470" y="1160" width="100" height="80" />
        <bpmndi:BPMNLabel />
