      <bpmndi:BPMNEdge id="Flow_SC_3_di" bpmnElement="Flow_SC_3">
        <di:waypoint x="570" y="860" />
        <di:waypoint x="630" y="860" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_SC_4_di" bpmnElement="Flow_SC_4">
        <di:waypoint x="730" y="860" />
        <di:waypoint x="790" y="860" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_SC_5_di" bpmnElement="Flow_SC_5">
        <di:waypoint x="890" y="860" />
        <di:waypoint x="950" y="860" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_SC_6_di" bpmnElement="Flow_SC_6">
        <di:waypoint x="1050" y="860" />
        <di:waypoint x="1110" y="860" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_SC_7_di" bpmnElement="Flow_SC_7">
        <di:waypoint x="1210" y="860" />
        <di:waypoint x="1272" y="860" />
      </bpmndi:BPMNEdge>

      <!-- ================================================
           POOL 4: ServiceNow Notification Service
           x=160, y=1100, width=700, height=200
           Tasks y=1160 | Events y=1182
           ================================================ -->
      <bpmndi:BPMNShape id="Participant_NotificationService_di" bpmnElement="Participant_NotificationService" isHorizontal="true">
        <dc:Bounds x="160" y="1100" width="700" height="200" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_NotificationService_di" bpmnElement="StartEvent_NotificationService">
        <dc:Bounds x="222" y="1182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="196" y="1225" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Task_Empfaengerliste_ermitteln_di" bpmnElement="Task_Empfaengerliste_ermitteln">
        <dc:Bounds x="310" y="1160" width="100" height="80" />
        <bpmndi:BPMNLabel />
