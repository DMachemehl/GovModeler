        <dc:Bounds x="792" y="1182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="766" y="1225" width="88" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Sequence Flows Pool 4 -->
      <bpmndi:BPMNEdge id="Flow_NS_1_di" bpmnElement="Flow_NS_1">
        <di:waypoint x="258" y="1200" />
        <di:waypoint x="310" y="1200" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_NS_2_di" bpmnElement="Flow_NS_2">
        <di:waypoint x="410" y="1200" />
        <di:waypoint x="470" y="1200" />
