        <di:waypoint x="730" y="1200" />
        <di:waypoint x="792" y="1200" />
      </bpmndi:BPMNEdge>

      <!-- ================================================
           MESSAGE FLOWS (Kollaboration zwischen Pools)
           ================================================ -->

      <!-- MsgFlow 1: API Gateway → CMDB
           Task_CMDB_Erstellung_ausloesen (x=790,y=140,w=100,h=80)
           Bottom-Center: x=840, y=220
           StartEvent_CMDB Center: x=240, y=520
           Routing: über Pool-Gap y=350 (zwischen y=280 und y=420)
      -->
      <bpmndi:BPMNEdge id="MsgFlow_CMDB_Erstellung_di" bpmnElement="MsgFlow_CMDB_Erstellung">
        <di:waypoint x="840" y="220" />
        <di:waypoint x="840" y="350" />
        <di:waypoint x="240" y="350" />
        <di:waypoint x="240" y="502" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="480" y="330" width="120" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- MsgFlow 2: CMDB → Service Catalog
           Task_Katalog_Eintrag_ausloesen (x=950,y=480,w=100,h=80)
           Bottom-Center: x=1000, y=560
           StartEvent_ServiceCatalog Center: x=240, y=860
           Routing: über Pool-Gap y=690 (zwischen y=620 und y=760)
      -->
      <bpmndi:BPMNEdge id="MsgFlow_Katalog_Registrierung_di" bpmnElement="MsgFlow_Katalog_Registrierung">
        <di:waypoint x="1000" y="560" />
        <di:waypoint x="1000" y="690" />
        <di:waypoint x="240" y="690" />
        <di:waypoint x="240" y="842" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="560" y="670" width="120" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- MsgFlow 3: Service Catalog → Notification Service
           Task_Benachrichtigung_ausloesen (x=1110,y=820,w=100,h=80)
           Bottom-Center: x=1160, y=900
           StartEvent_NotificationService Center: x=240, y=1200
           Routing: über Pool-Gap y=1030 (zwischen y=960 und y=1100)
      -->
      <bpmndi:BPMNEdge id="MsgFlow_Benachrichtigung_di" bpmnElement="MsgFlow_Benachrichtigung">
        <di:waypoint x="1160" y="900" />
        <di:waypoint x="1160" y="1030" />
        <di:waypoint x="240" y="1030" />
        <di:waypoint x="240" y="1182" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="640" y="1010" width="120" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
