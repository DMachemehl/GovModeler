      <bpmn:outgoing>Flow_Behoerde_Anfrage_Ausweisdaten</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="Event_Ausweisdaten_erhalten" name="Ausweisdaten erhalten">
