      <bpmn:messageEventDefinition id="MessageEventDef_Ausweisdaten" messageRef="Message_Ausweisdaten" />
    </bpmn:intermediateCatchEvent>
    <bpmn:userTask id="Task_Ausweis_ausgeben" name="Ausweis ausgeben">
