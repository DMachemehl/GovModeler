  <bpmn:collaboration id="Collab_Buechereiausweis_erstellen">
    <bpmn:participant id="Participant_Buerger" name="Buerger" processRef="Process_Buerger" />
    <bpmn:participant id="Participant_IT" name="IT" processRef="Process_IT" />
    <bpmn:participant id="Participant_Behoerde" name="Bibliothek" processRef="Process_Behoerde" />
    <bpmn:messageFlow id="MsgFlow_Antrag" name="Buechereiausweis-Antrag" sourceRef="Task_Antrag_absenden" targetRef="StartEvent_Antrag_eingegangen" />
    <bpmn:messageFlow id="MsgFlow_Ausweis" name="Buechereiausweis" sourceRef="Task_Ausweis_ausgeben" targetRef="Event_Ausweis_erhalten" />
    <bpmn:messageFlow id="MsgFlow_Registrierungsanfrage" name="Registrierungsanfrage" sourceRef="Task_Registrierungsanfrage_stellen" targetRef="StartEvent_Registrierungsanfrage_erhalten" />
    <bpmn:messageFlow id="MsgFlow_Ausweisdaten" name="Ausweisdaten" sourceRef="Task_Ausweisdaten_bereitstellen" targetRef="Event_Ausweisdaten_erhalten" />
  </bpmn:collaboration>

  <bpmn:process id="Process_Buerger" name="Buechereiausweis_erstellen_Buerger" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Buerger" name="Nutzungsbedarf festgestellt">
      <bpmn:outgoing>Flow_Buerger_Start_Ausfuellen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Antrag_ausfuellen" name="Antrag ausfuellen">
      <bpmn:incoming>Flow_Buerger_Start_Ausfuellen</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Ausfuellen_Nachweis</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Identitaetsnachweis_vorlegen" name="Identitaetsnachweis vorlegen">
      <bpmn:incoming>Flow_Buerger_Ausfuellen_Nachweis</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Nachweis_Absenden</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Antrag_absenden" name="Antrag absenden">
      <bpmn:incoming>Flow_Buerger_Nachweis_Absenden</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Absenden_Ausweis</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="Event_Ausweis_erhalten" name="Buechereiausweis erhalten">
      <bpmn:incoming>Flow_Buerger_Absenden_Ausweis</bpmn:incoming>
      <bpmn:outgoing>Flow_Buerger_Ausweis_Ende</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDef_Ausweis" messageRef="Message_Ausweis" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_Buerger" name="Buechereiausweis erstellt">
      <bpmn:incoming>Flow_Buerger_Ausweis_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Buerger_Start_Ausfuellen" sourceRef="StartEvent_Buerger" targetRef="Task_Antrag_ausfuellen" />
    <bpmn:sequenceFlow id="Flow_Buerger_Ausfuellen_Nachweis" sourceRef="Task_Antrag_ausfuellen" targetRef="Task_Identitaetsnachweis_vorlegen" />
    <bpmn:sequenceFlow id="Flow_Buerger_Nachweis_Absenden" sourceRef="Task_Identitaetsnachweis_vorlegen" targetRef="Task_Antrag_absenden" />
    <bpmn:sequenceFlow id="Flow_Buerger_Absenden_Ausweis" sourceRef="Task_Antrag_absenden" targetRef="Event_Ausweis_erhalten" />
    <bpmn:sequenceFlow id="Flow_Buerger_Ausweis_Ende" sourceRef="Event_Ausweis_erhalten" targetRef="EndEvent_Buerger" />
  </bpmn:process>

  <bpmn:process id="Process_IT" name="Buechereiausweis_erstellen_IT" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Registrierungsanfrage_erhalten" name="Registrierungsanfrage erhalten">
      <bpmn:outgoing>Flow_IT_Start_Erfassen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_Personendaten_erfassen" name="Personendaten erfassen">
      <bpmn:incoming>Flow_IT_Start_Erfassen</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Erfassen_Validieren</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Datensatz_validieren" name="Datensatz validieren">
      <bpmn:incoming>Flow_IT_Erfassen_Validieren</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Validieren_Erzeugen</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Buechereiausweis_erzeugen" name="Buechereiausweis erzeugen">
      <bpmn:incoming>Flow_IT_Validieren_Erzeugen</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Erzeugen_Bereitstellen</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Ausweisdaten_bereitstellen" name="Ausweisdaten bereitstellen">
      <bpmn:incoming>Flow_IT_Erzeugen_Bereitstellen</bpmn:incoming>
      <bpmn:outgoing>Flow_IT_Bereitstellen_Ende</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_IT" name="Ausweisdaten gesendet">
      <bpmn:incoming>Flow_IT_Bereitstellen_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_IT_Start_Erfassen" sourceRef="StartEvent_Registrierungsanfrage_erhalten" targetRef="Task_Personendaten_erfassen" />
    <bpmn:sequenceFlow id="Flow_IT_Erfassen_Validieren" sourceRef="Task_Personendaten_erfassen" targetRef="Task_Datensatz_validieren" />
    <bpmn:sequenceFlow id="Flow_IT_Validieren_Erzeugen" sourceRef="Task_Datensatz_validieren" targetRef="Task_Buechereiausweis_erzeugen" />
    <bpmn:sequenceFlow id="Flow_IT_Erzeugen_Bereitstellen" sourceRef="Task_Buechereiausweis_erzeugen" targetRef="Task_Ausweisdaten_bereitstellen" />
    <bpmn:sequenceFlow id="Flow_IT_Bereitstellen_Ende" sourceRef="Task_Ausweisdaten_bereitstellen" targetRef="EndEvent_IT" />
  </bpmn:process>

  <bpmn:process id="Process_Behoerde" name="Buechereiausweis_erstellen_Behoerde" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Antrag_eingegangen" name="Antrag eingegangen">
