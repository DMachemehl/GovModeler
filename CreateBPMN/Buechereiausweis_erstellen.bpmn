      <bpmn:outgoing>Flow_Behoerde_Ausgabe_Ende</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Behoerde" name="Buechereiausweis ausgegeben">
      <bpmn:incoming>Flow_Behoerde_Ausgabe_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Behoerde_Start_Entgegennehmen" sourceRef="StartEvent_Antrag_eingegangen" targetRef="Task_Antrag_entgegennehmen" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Entgegennehmen_Pruefen" sourceRef="Task_Antrag_entgegennehmen" targetRef="Task_Berechtigung_pruefen" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Pruefen_Anfrage" sourceRef="Task_Berechtigung_pruefen" targetRef="Task_Registrierungsanfrage_stellen" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Anfrage_Ausweisdaten" sourceRef="Task_Registrierungsanfrage_stellen" targetRef="Event_Ausweisdaten_erhalten" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Ausweisdaten_Ausgabe" sourceRef="Event_Ausweisdaten_erhalten" targetRef="Task_Ausweis_ausgeben" />
    <bpmn:sequenceFlow id="Flow_Behoerde_Ausgabe_Ende" sourceRef="Task_Ausweis_ausgeben" targetRef="EndEvent_Behoerde" />
  </bpmn:process>

