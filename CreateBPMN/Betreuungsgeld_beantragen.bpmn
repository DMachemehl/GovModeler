          <dc:Bounds x="1530" y="565" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Erfassen_di" bpmnElement="Flow_Start_Erfassen">
        <di:waypoint x="258" y="540" />
        <di:waypoint x="310" y="540" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Erfassen_Zustaendigkeit_di" bpmnElement="Flow_Erfassen_Zustaendigkeit">
        <di:waypoint x="410" y="540" />
        <di:waypoint x="470" y="540" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Zustaendigkeit_Vollstaendigkeit_di" bpmnElement="Flow_Zustaendigkeit_Vollstaendigkeit">
        <di:waypoint x="570" y="540" />
        <di:waypoint x="630" y="540" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Vollstaendigkeit_Anspruch_di" bpmnElement="Flow_Vollstaendigkeit_Anspruch">
