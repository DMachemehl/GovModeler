      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_Bescheid_empfangen_di" bpmnElement="Event_Bescheid_empfangen">
        <dc:Bounds x="632" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="622" y="144.5" width="56" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Kunde_di" bpmnElement="EndEvent_Kunde">
        <dc:Bounds x="1552" y="182" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1530" y="225" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Ausfuellen_di" bpmnElement="Flow_Start_Ausfuellen">
        <di:waypoint x="258" y="200" />
        <di:waypoint x="310" y="200" />
      </bpmndi:BPMNEdge>
