      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Anspruch_Berechnen_di" bpmnElement="Flow_Anspruch_Berechnen">
        <di:waypoint x="890" y="540" />
        <di:waypoint x="950" y="540" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Berechnen_Erstellen_di" bpmnElement="Flow_Berechnen_Erstellen">
        <di:waypoint x="1050" y="540" />
        <di:waypoint x="1110" y="540" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Erstellen_Versenden_di" bpmnElement="Flow_Erstellen_Versenden">
