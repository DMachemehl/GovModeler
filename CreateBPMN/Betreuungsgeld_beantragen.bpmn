<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://example.com/bpmn" exporter="GitHub-Copilot-GovModeler" exporterVersion="2.0">
  <bpmn:collaboration id="Collab_Betreuungsgeld_beantragen">
    <bpmn:participant id="Participant_Kunde" name="Kunde" processRef="Process_Kunde" />
    <bpmn:participant id="Participant_Organisation" name="Organisation" processRef="Process_Organisation" />
    <bpmn:messageFlow id="MsgFlow_Antrag" name="Betreuungsgeld-Antrag" sourceRef="Task_Antrag_einreichen" targetRef="StartEvent_Antrag_eingegangen" />
    <bpmn:messageFlow id="MsgFlow_Bescheid" name="Bewilligungsbescheid" sourceRef="Task_Bescheid_versenden" targetRef="Event_Bescheid_empfangen" />
  </bpmn:collaboration>
  <bpmn:process id="Process_Kunde" name="Betreuungsgeld_beantragen_Kunde" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Kunde" name="Bedarf festgestellt">
      <bpmn:outgoing>Flow_Start_Ausfuellen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Antrag_ausfuellen" name="Antrag ausfuellen">
      <bpmn:incoming>Flow_Start_Ausfuellen</bpmn:incoming>
      <bpmn:outgoing>Flow_Ausfuellen_Einreichen</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Antrag_einreichen" name="Antrag einreichen">
      <bpmn:incoming>Flow_Ausfuellen_Einreichen</bpmn:incoming>
      <bpmn:outgoing>Flow_Einreichen_Warten</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:intermediateCatchEvent id="Event_Bescheid_empfangen" name="Bescheid empfangen">
      <bpmn:incoming>Flow_Einreichen_Warten</bpmn:incoming>
      <bpmn:outgoing>Flow_Bescheid_Ende</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MessageEventDef_Bescheid" messageRef="Message_Bescheid" />
    </bpmn:intermediateCatchEvent>
    <bpmn:endEvent id="EndEvent_Kunde" name="Betreuungsgeld bewilligt">
      <bpmn:incoming>Flow_Bescheid_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Ausfuellen" sourceRef="StartEvent_Kunde" targetRef="Task_Antrag_ausfuellen" />
    <bpmn:sequenceFlow id="Flow_Ausfuellen_Einreichen" sourceRef="Task_Antrag_ausfuellen" targetRef="Task_Antrag_einreichen" />
    <bpmn:sequenceFlow id="Flow_Einreichen_Warten" sourceRef="Task_Antrag_einreichen" targetRef="Event_Bescheid_empfangen" />
    <bpmn:sequenceFlow id="Flow_Bescheid_Ende" sourceRef="Event_Bescheid_empfangen" targetRef="EndEvent_Kunde" />
  </bpmn:process>
  <bpmn:process id="Process_Organisation" name="Betreuungsgeld_bearbeiten_Organisation" isExecutable="true">
    <bpmn:startEvent id="StartEvent_Antrag_eingegangen" name="Antrag eingegangen">
      <bpmn:outgoing>Flow_Start_Erfassen</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_Eingang_erfassen" name="Eingang erfassen">
      <bpmn:incoming>Flow_Start_Erfassen</bpmn:incoming>
      <bpmn:outgoing>Flow_Erfassen_Zustaendigkeit</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_Zustaendigkeit_pruefen" name="Zustaendigkeit pruefen">
      <bpmn:incoming>Flow_Erfassen_Zustaendigkeit</bpmn:incoming>
      <bpmn:outgoing>Flow_Zustaendigkeit_Vollstaendigkeit</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_Vollstaendigkeit_pruefen" name="Vollstaendigkeit pruefen">
      <bpmn:incoming>Flow_Zustaendigkeit_Vollstaendigkeit</bpmn:incoming>
      <bpmn:outgoing>Flow_Vollstaendigkeit_Anspruch</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_Anspruch_pruefen" name="Anspruchsvoraussetzungen pruefen">
      <bpmn:incoming>Flow_Vollstaendigkeit_Anspruch</bpmn:incoming>
      <bpmn:outgoing>Flow_Anspruch_Berechnen</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_Hoehe_berechnen" name="Hoehe berechnen">
      <bpmn:incoming>Flow_Anspruch_Berechnen</bpmn:incoming>
      <bpmn:outgoing>Flow_Berechnen_Erstellen</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_Bescheid_erstellen" name="Bescheid erstellen">
      <bpmn:incoming>Flow_Berechnen_Erstellen</bpmn:incoming>
      <bpmn:outgoing>Flow_Erstellen_Versenden</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_Bescheid_versenden" name="Bescheid versenden">
      <bpmn:incoming>Flow_Erstellen_Versenden</bpmn:incoming>
      <bpmn:outgoing>Flow_Versenden_Ende</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Organisation" name="Prozess abgeschlossen">
      <bpmn:incoming>Flow_Versenden_Ende</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_Start_Erfassen" sourceRef="StartEvent_Antrag_eingegangen" targetRef="Task_Eingang_erfassen" />
    <bpmn:sequenceFlow id="Flow_Erfassen_Zustaendigkeit" sourceRef="Task_Eingang_erfassen" targetRef="Task_Zustaendigkeit_pruefen" />
    <bpmn:sequenceFlow id="Flow_Zustaendigkeit_Vollstaendigkeit" sourceRef="Task_Zustaendigkeit_pruefen" targetRef="Task_Vollstaendigkeit_pruefen" />
    <bpmn:sequenceFlow id="Flow_Vollstaendigkeit_Anspruch" sourceRef="Task_Vollstaendigkeit_pruefen" targetRef="Task_Anspruch_pruefen" />
    <bpmn:sequenceFlow id="Flow_Anspruch_Berechnen" sourceRef="Task_Anspruch_pruefen" targetRef="Task_Hoehe_berechnen" />
    <bpmn:sequenceFlow id="Flow_Berechnen_Erstellen" sourceRef="Task_Hoehe_berechnen" targetRef="Task_Bescheid_erstellen" />
    <bpmn:sequenceFlow id="Flow_Erstellen_Versenden" sourceRef="Task_Bescheid_erstellen" targetRef="Task_Bescheid_versenden" />
    <bpmn:sequenceFlow id="Flow_Versenden_Ende" sourceRef="Task_Bescheid_versenden" targetRef="EndEvent_Organisation" />
  </bpmn:process>
  <bpmn:message id="Message_Antrag" name="Betreuungsgeld-Antrag" />
  <bpmn:message id="Message_Bescheid" name="Bewilligungsbescheid" />
  <bpmndi:BPMNDiagram id="BPMNDiagram_Betreuungsgeld">
    <bpmndi:BPMNPlane id="BPMNPlane_Betreuungsgeld" bpmnElement="Collab_Betreuungsgeld_beantragen">
      <bpmndi:BPMNShape id="Participant_Kunde_di" bpmnElement="Participant_Kunde" isHorizontal="true">
        <dc:Bounds x="160" y="80" width="1500" height="250" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="170" y="190" width="20" height="50" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_Kunde_di" bpmnElement="StartEvent_Kunde">
