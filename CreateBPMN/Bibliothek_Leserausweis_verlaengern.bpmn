          <omgdc:Bounds height="27" width="80" x="870" y="253"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- MsgFlow 6: End Event → Kunde (vertikal nach oben) -->
      <bpmndi:BPMNEdge bpmnElement="_d8e9f0a1-b2c3-4567-5678-678901234567"
                       id="BPMN_Edge_d8e9f0a1-b2c3-4567-5678-678901234567">
