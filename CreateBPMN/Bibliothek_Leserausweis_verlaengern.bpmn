      <!-- MsgFlow 5: IT → Task 5 (vertikal nach oben) -->
      <bpmndi:BPMNEdge bpmnElement="_c7d8e9f0-a1b2-3456-4567-567890123456"
                       id="BPMN_Edge_c7d8e9f0-a1b2-3456-4567-567890123456">
        <omgdi:waypoint x="860" y="303"/>
