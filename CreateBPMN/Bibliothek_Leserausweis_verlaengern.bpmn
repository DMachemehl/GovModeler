  <!-- =====================================================
       KOLLABORATION: Leserausweis verlaengern
       Stadtbibliothek Stuttgart
       3-Pool: Kunde (Black-Box), Organisation (White-Box), IT - aDIS/BMS (Black-Box)
       ===================================================== -->
  <collaboration id="Collaboration_b2c3d4e5-f6a7-8901-bcde-f12345678901"
                 name="Leserausweis verlaengern"
                 isClosed="false">

    <!-- Participants (Reihenfolge: Organisation, Kunde, IT) -->
    <participant processRef="process_d4e5f6a7-b8c9-0123-def0-234567890123"
                 name="Organisation"
                 id="_c3d4e5f6-a7b8-9012-cdef-123456789012"/>
    <participant processRef="process_f6a7b8c9-d0e1-2345-f012-456789012345"
                 name="Kunde"
                 id="_e5f6a7b8-c9d0-1234-ef01-345678901234"/>
    <participant processRef="process_b8c9d0e1-f2a3-4567-1234-678901234567"
                 name="IT - aDIS/BMS"
                 id="_a7b8c9d0-e1f2-3456-0123-567890123456"/>

    <!-- =====================================================
         MESSAGE FLOWS
         ===================================================== -->

    <!-- Message Flow 1: Kunde → Start Event (Verlaengerungswunsch mit Ausweis) -->
    <messageFlow id="_e3f4a5b6-c7d8-9012-0123-123456789012"
                 name="Verlaengerungswunsch mit Ausweis"
                 sourceRef="_e5f6a7b8-c9d0-1234-ef01-345678901234"
                 targetRef="_d0e1f2a3-b4c5-6789-3456-890123456789">
      <extensionElements>
        <adonis:connector>
          <adonis:attribute name="DISPLAY_DENOMNIATION" type="BOOL" notebook="1" sourcelang="" novalue="0">
            <adonis:value>true</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
          <adonis:attribute name="REPRESENTATION_HAS_PROCESS" type="ENUM" notebook="1" sourcelang="" novalue="0" lang-independent="v0">
            <adonis:value>automatisch</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
        </adonis:connector>
      </extensionElements>
    </messageFlow>

    <!-- Message Flow 2: Task Benutzerkonto abfragen → IT (Kontodatenabfrage) -->
    <messageFlow id="_f4a5b6c7-d8e9-0123-1234-234567890123"
                 name="Kontodatenabfrage"
                 sourceRef="_f2a3b4c5-d6e7-8901-5678-012345678901"
                 targetRef="_a7b8c9d0-e1f2-3456-0123-567890123456">
      <extensionElements>
        <adonis:connector>
          <adonis:attribute name="DISPLAY_DENOMNIATION" type="BOOL" notebook="1" sourcelang="" novalue="0">
            <adonis:value>true</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
          <adonis:attribute name="REPRESENTATION_HAS_PROCESS" type="ENUM" notebook="1" sourcelang="" novalue="0" lang-independent="v0">
            <adonis:value>automatisch</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
        </adonis:connector>
      </extensionElements>
    </messageFlow>

    <!-- Message Flow 3: IT → Task Gebuehren pruefen und kassieren (Benutzerkontodaten) -->
    <messageFlow id="_a5b6c7d8-e9f0-1234-2345-345678901234"
                 name="Benutzerkontodaten"
                 sourceRef="_a7b8c9d0-e1f2-3456-0123-567890123456"
                 targetRef="_a3b4c5d6-e7f8-9012-6789-123456789012">
      <extensionElements>
        <adonis:connector>
          <adonis:attribute name="DISPLAY_DENOMNIATION" type="BOOL" notebook="1" sourcelang="" novalue="0">
            <adonis:value>true</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
          <adonis:attribute name="REPRESENTATION_HAS_PROCESS" type="ENUM" notebook="1" sourcelang="" novalue="0" lang-independent="v0">
            <adonis:value>automatisch</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
        </adonis:connector>
      </extensionElements>
    </messageFlow>

    <!-- Message Flow 4: Task Verlaengerung buchen → IT (Verlaengerungsbuchung) -->
    <messageFlow id="_b6c7d8e9-f0a1-2345-3456-456789012345"
                 name="Verlaengerungsbuchung"
                 sourceRef="_b4c5d6e7-f8a9-0123-789a-234567890123"
                 targetRef="_a7b8c9d0-e1f2-3456-0123-567890123456">
      <extensionElements>
        <adonis:connector>
          <adonis:attribute name="DISPLAY_DENOMNIATION" type="BOOL" notebook="1" sourcelang="" novalue="0">
            <adonis:value>true</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
          <adonis:attribute name="REPRESENTATION_HAS_PROCESS" type="ENUM" notebook="1" sourcelang="" novalue="0" lang-independent="v0">
            <adonis:value>automatisch</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
        </adonis:connector>
      </extensionElements>
    </messageFlow>

    <!-- Message Flow 5: IT → Task Bestaetigung aushaendigen (Buchungsbestaetigung) -->
    <messageFlow id="_c7d8e9f0-a1b2-3456-4567-567890123456"
                 name="Buchungsbestaetigung"
                 sourceRef="_a7b8c9d0-e1f2-3456-0123-567890123456"
                 targetRef="_c5d6e7f8-a9b0-1234-89ab-345678901234">
      <extensionElements>
        <adonis:connector>
          <adonis:attribute name="DISPLAY_DENOMNIATION" type="BOOL" notebook="1" sourcelang="" novalue="0">
            <adonis:value>true</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
          <adonis:attribute name="REPRESENTATION_HAS_PROCESS" type="ENUM" notebook="1" sourcelang="" novalue="0" lang-independent="v0">
            <adonis:value>automatisch</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
        </adonis:connector>
      </extensionElements>
    </messageFlow>

    <!-- Message Flow 6: End Event → Kunde (Verlaengerungsbestaetigung) -->
    <messageFlow id="_d8e9f0a1-b2c3-4567-5678-678901234567"
                 name="Verlaengerungsbestaetigung"
                 sourceRef="_d6e7f8a9-b0c1-2345-9abc-456789012345"
                 targetRef="_e5f6a7b8-c9d0-1234-ef01-345678901234">
      <extensionElements>
        <adonis:connector>
          <adonis:attribute name="DISPLAY_DENOMNIATION" type="BOOL" notebook="1" sourcelang="" novalue="0">
            <adonis:value>true</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
          <adonis:attribute name="REPRESENTATION_HAS_PROCESS" type="ENUM" notebook="1" sourcelang="" novalue="0" lang-independent="v0">
            <adonis:value>automatisch</adonis:value>
            <adonis:metavalue/>
          </adonis:attribute>
        </adonis:connector>
      </extensionElements>
    </messageFlow>

  </collaboration>

  <!-- =====================================================
       PROZESS: Organisation (White-Box Pool)
       Lane: Ausleihe
       ===================================================== -->
  <process name="Organisation"
           id="process_d4e5f6a7-b8c9-0123-def0-234567890123"
           isExecutable="false"
           isClosed="false"
           processType="None">

    <laneSet id="laneSet_d4e5f6a7-b8c9-0123-def0-234567890123">
      <lane name="Ausleihe" id="_c9d0e1f2-a3b4-5678-2345-789012345678">
        <flowNodeRef>_d0e1f2a3-b4c5-6789-3456-890123456789</flowNodeRef>
        <flowNodeRef>_e1f2a3b4-c5d6-7890-4567-901234567890</flowNodeRef>
        <flowNodeRef>_f2a3b4c5-d6e7-8901-5678-012345678901</flowNodeRef>
        <flowNodeRef>_a3b4c5d6-e7f8-9012-6789-123456789012</flowNodeRef>
        <flowNodeRef>_b4c5d6e7-f8a9-0123-789a-234567890123</flowNodeRef>
        <flowNodeRef>_c5d6e7f8-a9b0-1234-89ab-345678901234</flowNodeRef>
        <flowNodeRef>_d6e7f8a9-b0c1-2345-9abc-456789012345</flowNodeRef>
      </lane>
    </laneSet>

    <!-- Start Event (Message): Verlaengerungsantrag eingegangen -->
    <startEvent name="Verlaengerungsantrag eingegangen"
                id="_d0e1f2a3-b4c5-6789-3456-890123456789">
      <outgoing>_e7f8a9b0-c1d2-3456-abcd-567890123456</outgoing>
      <messageEventDefinition id="msgEvtDef_e9f0a1b2-c3d4-5678-6789-789012345678"/>
    </startEvent>

    <!-- Task 1: Ausweis und Identitaet pruefen -->
    <task name="Ausweis und Identitaet pruefen"
          id="_e1f2a3b4-c5d6-7890-4567-901234567890"
          isForCompensation="false">
      <incoming>_e7f8a9b0-c1d2-3456-abcd-567890123456</incoming>
      <outgoing>_f8a9b0c1-d2e3-4567-bcde-678901234567</outgoing>
    </task>

    <!-- Task 2: Benutzerkonto abfragen (sendet an IT) -->
    <task name="Benutzerkonto abfragen"
          id="_f2a3b4c5-d6e7-8901-5678-012345678901"
          isForCompensation="false">
      <incoming>_f8a9b0c1-d2e3-4567-bcde-678901234567</incoming>
      <outgoing>_a9b0c1d2-e3f4-5678-cdef-789012345678</outgoing>
    </task>

    <!-- Task 3: Gebuehren pruefen und kassieren (empfaengt von IT) -->
    <task name="Gebuehren pruefen und kassieren"
          id="_a3b4c5d6-e7f8-9012-6789-123456789012"
          isForCompensation="false">
      <incoming>_a9b0c1d2-e3f4-5678-cdef-789012345678</incoming>
      <outgoing>_b0c1d2e3-f4a5-6789-def0-890123456789</outgoing>
    </task>

    <!-- Task 4: Verlaengerung buchen (sendet an IT) -->
    <task name="Verlaengerung buchen"
          id="_b4c5d6e7-f8a9-0123-789a-234567890123"
          isForCompensation="false">
      <incoming>_b0c1d2e3-f4a5-6789-def0-890123456789</incoming>
      <outgoing>_c1d2e3f4-a5b6-7890-ef01-901234567890</outgoing>
    </task>

    <!-- Task 5: Bestaetigung aushaendigen (empfaengt von IT) -->
    <task name="Bestaetigung aushaendigen"
          id="_c5d6e7f8-a9b0-1234-89ab-345678901234"
          isForCompensation="false">
      <incoming>_c1d2e3f4-a5b6-7890-ef01-901234567890</incoming>
      <outgoing>_d2e3f4a5-b6c7-8901-f012-012345678901</outgoing>
    </task>

    <!-- End Event (Message): Leserausweis verlaengert (sendet an Kunde) -->
    <endEvent name="Leserausweis verlaengert"
              id="_d6e7f8a9-b0c1-2345-9abc-456789012345">
      <incoming>_d2e3f4a5-b6c7-8901-f012-012345678901</incoming>
      <messageEventDefinition id="msgEvtDef_f0a1b2c3-d4e5-6789-789a-890123456789"/>
    </endEvent>

    <!-- Sequence Flows -->
    <sequenceFlow sourceRef="_d0e1f2a3-b4c5-6789-3456-890123456789"
                  targetRef="_e1f2a3b4-c5d6-7890-4567-901234567890"
                  id="_e7f8a9b0-c1d2-3456-abcd-567890123456"/>
    <sequenceFlow sourceRef="_e1f2a3b4-c5d6-7890-4567-901234567890"
                  targetRef="_f2a3b4c5-d6e7-8901-5678-012345678901"
                  id="_f8a9b0c1-d2e3-4567-bcde-678901234567"/>
    <sequenceFlow sourceRef="_f2a3b4c5-d6e7-8901-5678-012345678901"
                  targetRef="_a3b4c5d6-e7f8-9012-6789-123456789012"
                  id="_a9b0c1d2-e3f4-5678-cdef-789012345678"/>
    <sequenceFlow sourceRef="_a3b4c5d6-e7f8-9012-6789-123456789012"
                  targetRef="_b4c5d6e7-f8a9-0123-789a-234567890123"
                  id="_b0c1d2e3-f4a5-6789-def0-890123456789"/>
    <sequenceFlow sourceRef="_b4c5d6e7-f8a9-0123-789a-234567890123"
                  targetRef="_c5d6e7f8-a9b0-1234-89ab-345678901234"
                  id="_c1d2e3f4-a5b6-7890-ef01-901234567890"/>
    <sequenceFlow sourceRef="_c5d6e7f8-a9b0-1234-89ab-345678901234"
                  targetRef="_d6e7f8a9-b0c1-2345-9abc-456789012345"
                  id="_d2e3f4a5-b6c7-8901-f012-012345678901"/>

  </process>

  <!-- =====================================================
       PROZESS: Kunde (Black-Box Pool)
       KEINE internen Prozesselemente
       ===================================================== -->
  <process name="Kunde"
           id="process_f6a7b8c9-d0e1-2345-f012-456789012345"
           isExecutable="false"
           isClosed="false"
           processType="None">
    <!-- Black-Box Pool: Keine internen Elemente -->
  </process>

  <!-- =====================================================
       PROZESS: IT - aDIS/BMS (Black-Box Pool)
       KEINE internen Prozesselemente
       ===================================================== -->
  <process name="IT - aDIS/BMS"
           id="process_b8c9d0e1-f2a3-4567-1234-678901234567"
           isExecutable="false"
           isClosed="false"
           processType="None">
    <!-- Black-Box Pool: Keine internen Elemente -->
  </process>

  <!-- =====================================================
       BPMN-DI: Visuelle Darstellung
       Pool-Anordnung (vertikal):
         Kunde:         y=0,   height=57
         Organisation:  y=95,  height=170
         IT:            y=303, height=57
       Tasks in Lane:   y=140, height=80, width=100
       Events in Lane:  y=152, height=36, width=36
       Pool-Breite:     1200px
       ===================================================== -->
  <bpmndi:BPMNDiagram id="Diagram_b2c3d4e5-f6a7-8901-bcde-f12345678901"
                      name="Leserausweis verlaengern">
    <bpmndi:BPMNPlane id="BPMNPlane_b2c3d4e5-f6a7-8901-bcde-f12345678901"
                      bpmnElement="Collaboration_b2c3d4e5-f6a7-8901-bcde-f12345678901">

      <!-- ================================================
           POOL: Kunde (Black-Box, oben)
           y=0, height=57, width=1200
           ================================================ -->
      <bpmndi:BPMNShape bpmnElement="_e5f6a7b8-c9d0-1234-ef01-345678901234"
                        isHorizontal="true"
                        id="BPMN_Shape_e5f6a7b8-c9d0-1234-ef01-345678901234">
        <omgdc:Bounds height="57" width="1200" x="0" y="0"/>
      </bpmndi:BPMNShape>

      <!-- ================================================
           POOL: Organisation (White-Box, Mitte)
           y=95, height=170, width=1200
           ================================================ -->
      <bpmndi:BPMNShape bpmnElement="_c3d4e5f6-a7b8-9012-cdef-123456789012"
                        isHorizontal="true"
                        id="BPMN_Shape_c3d4e5f6-a7b8-9012-cdef-123456789012">
        <omgdc:Bounds height="170" width="1200" x="0" y="95"/>
      </bpmndi:BPMNShape>

      <!-- Lane: Ausleihe (innerhalb Organisation) -->
      <bpmndi:BPMNShape bpmnElement="_c9d0e1f2-a3b4-5678-2345-789012345678"
                        isHorizontal="true"
                        id="BPMN_Shape_c9d0e1f2-a3b4-5678-2345-789012345678">
        <omgdc:Bounds height="170" width="1160" x="40" y="95"/>
      </bpmndi:BPMNShape>

      <!-- ================================================
           POOL: IT - aDIS/BMS (Black-Box, unten)
           y=303, height=57, width=1200
           ================================================ -->
      <bpmndi:BPMNShape bpmnElement="_a7b8c9d0-e1f2-3456-0123-567890123456"
                        isHorizontal="true"
                        id="BPMN_Shape_a7b8c9d0-e1f2-3456-0123-567890123456">
        <omgdc:Bounds height="57" width="1200" x="0" y="303"/>
      </bpmndi:BPMNShape>

      <!-- ================================================
           PROZESSELEMENTE: Organisation / Ausleihe
           Alle Tasks: y=140, height=80, width=100
           Alle Events: y=152, height=36, width=36
           X-Abstand: 160px (Task-Breite 100 + Abstand 60)
           ================================================ -->

      <!-- Start Event: x=80, y=152 (center: 98, 170) -->
      <bpmndi:BPMNShape bpmnElement="_d0e1f2a3-b4c5-6789-3456-890123456789"
                        id="BPMN_Shape_d0e1f2a3-b4c5-6789-3456-890123456789">
        <omgdc:Bounds height="36" width="36" x="80" y="152"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds height="27" width="90" x="55" y="193"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- Task 1: Ausweis und Identitaet pruefen (x=170, y=140) -->
      <bpmndi:BPMNShape bpmnElement="_e1f2a3b4-c5d6-7890-4567-901234567890"
                        id="BPMN_Shape_e1f2a3b4-c5d6-7890-4567-901234567890">
        <omgdc:Bounds height="80" width="100" x="170" y="140"/>
      </bpmndi:BPMNShape>

      <!-- Task 2: Benutzerkonto abfragen (x=330, y=140) -->
      <bpmndi:BPMNShape bpmnElement="_f2a3b4c5-d6e7-8901-5678-012345678901"
                        id="BPMN_Shape_f2a3b4c5-d6e7-8901-5678-012345678901">
        <omgdc:Bounds height="80" width="100" x="330" y="140"/>
      </bpmndi:BPMNShape>

      <!-- Task 3: Gebuehren pruefen und kassieren (x=490, y=140) -->
      <bpmndi:BPMNShape bpmnElement="_a3b4c5d6-e7f8-9012-6789-123456789012"
                        id="BPMN_Shape_a3b4c5d6-e7f8-9012-6789-123456789012">
        <omgdc:Bounds height="80" width="100" x="490" y="140"/>
      </bpmndi:BPMNShape>

      <!-- Task 4: Verlaengerung buchen (x=650, y=140) -->
      <bpmndi:BPMNShape bpmnElement="_b4c5d6e7-f8a9-0123-789a-234567890123"
                        id="BPMN_Shape_b4c5d6e7-f8a9-0123-789a-234567890123">
        <omgdc:Bounds height="80" width="100" x="650" y="140"/>
      </bpmndi:BPMNShape>

      <!-- Task 5: Bestaetigung aushaendigen (x=810, y=140) -->
      <bpmndi:BPMNShape bpmnElement="_c5d6e7f8-a9b0-1234-89ab-345678901234"
                        id="BPMN_Shape_c5d6e7f8-a9b0-1234-89ab-345678901234">
        <omgdc:Bounds height="80" width="100" x="810" y="140"/>
      </bpmndi:BPMNShape>

      <!-- End Event: x=970, y=152 (center: 988, 170) -->
      <bpmndi:BPMNShape bpmnElement="_d6e7f8a9-b0c1-2345-9abc-456789012345"
                        id="BPMN_Shape_d6e7f8a9-b0c1-2345-9abc-456789012345">
        <omgdc:Bounds height="36" width="36" x="970" y="152"/>
        <bpmndi:BPMNLabel>
          <omgdc:Bounds height="27" width="90" x="945" y="193"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ================================================
           SEQUENCE FLOWS (alle horizontal auf y=170/180)
           ================================================ -->

      <!-- Flow 1: Start Event → Task 1 -->
      <bpmndi:BPMNEdge bpmnElement="_e7f8a9b0-c1d2-3456-abcd-567890123456"
                       id="BPMN_Edge_e7f8a9b0-c1d2-3456-abcd-567890123456">
        <omgdi:waypoint x="116" y="170"/>
        <omgdi:waypoint x="170" y="170"/>
      </bpmndi:BPMNEdge>

      <!-- Flow 2: Task 1 → Task 2 -->
      <bpmndi:BPMNEdge bpmnElement="_f8a9b0c1-d2e3-4567-bcde-678901234567"
                       id="BPMN_Edge_f8a9b0c1-d2e3-4567-bcde-678901234567">
        <omgdi:waypoint x="270" y="180"/>
        <omgdi:waypoint x="330" y="180"/>
      </bpmndi:BPMNEdge>

      <!-- Flow 3: Task 2 → Task 3 -->
      <bpmndi:BPMNEdge bpmnElement="_a9b0c1d2-e3f4-5678-cdef-789012345678"
                       id="BPMN_Edge_a9b0c1d2-e3f4-5678-cdef-789012345678">
        <omgdi:waypoint x="430" y="180"/>
        <omgdi:waypoint x="490" y="180"/>
      </bpmndi:BPMNEdge>

      <!-- Flow 4: Task 3 → Task 4 -->
      <bpmndi:BPMNEdge bpmnElement="_b0c1d2e3-f4a5-6789-def0-890123456789"
                       id="BPMN_Edge_b0c1d2e3-f4a5-6789-def0-890123456789">
        <omgdi:waypoint x="590" y="180"/>
        <omgdi:waypoint x="650" y="180"/>
      </bpmndi:BPMNEdge>

      <!-- Flow 5: Task 4 → Task 5 -->
      <bpmndi:BPMNEdge bpmnElement="_c1d2e3f4-a5b6-7890-ef01-901234567890"
                       id="BPMN_Edge_c1d2e3f4-a5b6-7890-ef01-901234567890">
        <omgdi:waypoint x="750" y="180"/>
        <omgdi:waypoint x="810" y="180"/>
      </bpmndi:BPMNEdge>

      <!-- Flow 6: Task 5 → End Event -->
      <bpmndi:BPMNEdge bpmnElement="_d2e3f4a5-b6c7-8901-f012-012345678901"
                       id="BPMN_Edge_d2e3f4a5-b6c7-8901-f012-012345678901">
        <omgdi:waypoint x="910" y="180"/>
        <omgdi:waypoint x="970" y="170"/>
      </bpmndi:BPMNEdge>

      <!-- ================================================
           MESSAGE FLOWS
           Kunde Pool:        y=0   bis y=57
           Organisation Pool: y=95  bis y=265
           IT Pool:           y=303 bis y=360
           ================================================ -->

      <!-- MsgFlow 1: Kunde → Start Event (vertikal nach unten) -->
      <bpmndi:BPMNEdge bpmnElement="_e3f4a5b6-c7d8-9012-0123-123456789012"
                       id="BPMN_Edge_e3f4a5b6-c7d8-9012-0123-123456789012">
