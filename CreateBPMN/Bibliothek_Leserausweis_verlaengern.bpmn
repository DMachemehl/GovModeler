      </bpmndi:BPMNEdge>

      <!-- MsgFlow 4: Task 4 → IT (vertikal nach unten) -->
      <bpmndi:BPMNEdge bpmnElement="_b6c7d8e9-f0a1-2345-3456-456789012345"
                       id="BPMN_Edge_b6c7d8e9-f0a1-2345-3456-456789012345">
        <omgdi:waypoint x="700" y="220"/>
