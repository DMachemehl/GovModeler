      </bpmndi:BPMNEdge>

      <!-- MsgFlow 2: Task 2 → IT (vertikal nach unten) -->
      <bpmndi:BPMNEdge bpmnElement="_f4a5b6c7-d8e9-0123-1234-234567890123"
                       id="BPMN_Edge_f4a5b6c7-d8e9-0123-1234-234567890123">
