<?xml version="1.0" encoding="utf-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:adonis="http://www.boc-group.com"
             xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definition_bib_tp5_medien_vermitteln"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd"
             targetNamespace="http://www.boc-group.com">

  <!-- =====================================================
       COLLABORATION: TP5 Medien vermitteln
       Uebergeordneter Prozess: Medien managen
       Stadtbibliothek Stuttgart

       Struktur: 2-Pool-Kollaboration (Kunde | Organisation)
         Kunde:        y=0,   Hoehe=380  | Tasks y=152, Events y=172, Center y=190
         Organisation: y=390, Hoehe=600  | 2 Lanes (je 300px)
           Lane 1 Auskunft/Info & Veranstaltungen: y=390, Center y=540
           Lane 2 Digitale Dienste:                y=690, Center y=840

       Supplier: TP1 Umfeldanalyse → Bestandsprofil als Vermittlungsgrundlage
       Happy Path: Informationsbedarf geaeussert → Medium wird genutzt

       Message Flows (bidirektional):
         K1 → Org-Start: Rechercheanfrage / Informationsbedarf
         O6  → K2:       Medienempfehlung
       ===================================================== -->
  <collaboration id="Collaboration_bib_tp5_medien_vermitteln"
                 name="TP5 Medien vermitteln | Medien managen"
                 isClosed="false">

    <participant processRef="process_Kunde_tp5"
                 name="Kunde"
                 id="_Kunde_Participant_tp5"/>
    <participant processRef="process_Org_tp5"
                 name="Organisation"
                 id="_Org_Participant_tp5"/>

    <!-- Message Flow 1: Kunde → Organisation -->
    <!-- Bibliotheksnutzer stellt Rechercheanfrage / aeussert Informationsbedarf -->
    <messageFlow id="_MF_K_to_Org_tp5"
                 name="Rechercheanfrage / Informationsbedarf"
                 sourceRef="_Kunde_Task_K1_tp5"
                 targetRef="_Org_Start_tp5"/>

    <!-- Message Flow 2: Organisation → Kunde -->
    <!-- Auskunft/Information spricht Medienempfehlung aus -->
    <messageFlow id="_MF_Org_to_K_tp5"
                 name="Medienempfehlung"
                 sourceRef="_Org_Task_O6_tp5"
                 targetRef="_Kunde_Task_K2_tp5"/>

  </collaboration>

  <!-- =====================================================
       PROZESS: Kunde (Bibliotheksnutzer/-in)
       e2e-Rahmen: Informationsbedarf festgestellt → Medium wird genutzt
       ===================================================== -->
  <process name="Kunde"
           id="process_Kunde_tp5"
           isExecutable="false"
           isClosed="false"
           processType="None">

    <laneSet id="laneSet_Kunde_tp5">
      <lane name="Bibliotheksnutzer/-in" id="_Kunde_Lane_tp5">
        <flowNodeRef>_Kunde_Start_tp5</flowNodeRef>
        <flowNodeRef>_Kunde_Task_K1_tp5</flowNodeRef>
        <flowNodeRef>_Kunde_Task_K2_tp5</flowNodeRef>
        <flowNodeRef>_Kunde_Task_K3_tp5</flowNodeRef>
        <flowNodeRef>_Kunde_End_tp5</flowNodeRef>
      </lane>
    </laneSet>

    <!-- Start Event: Informationsbedarf festgestellt -->
    <startEvent name="Informationsbedarf&#10;festgestellt" id="_Kunde_Start_tp5">
      <outgoing>_Kunde_Flow_01_tp5</outgoing>
    </startEvent>

    <!-- K1: Rechercheanfrage stellen -->
    <!-- Kunde aeussert Informationsbedarf oder Medienwunsch -->
    <!-- persoenlich, per OPAC/KI-Chatbot, per E-Mail oder bei Veranstaltung -->
    <task name="Rechercheanfrage&#10;stellen" id="_Kunde_Task_K1_tp5" isForCompensation="false">
      <incoming>_Kunde_Flow_01_tp5</incoming>
      <outgoing>_Kunde_Flow_02_tp5</outgoing>
    </task>

    <!-- K2: Medienempfehlung entgegennehmen -->
    <!-- Bibliotheksnutzer erhaelt zielgruppengerechte Medienempfehlung, -->
    <!-- Themenwelt-Hinweis oder Einfuehrung in digitale Angebote -->
    <task name="Medienempfehlung&#10;entgegennehmen" id="_Kunde_Task_K2_tp5" isForCompensation="false">
      <incoming>_Kunde_Flow_02_tp5</incoming>
      <outgoing>_Kunde_Flow_03_tp5</outgoing>
    </task>

    <!-- K3: Medium auswaehlen und nutzen -->
    <!-- Bibliotheksnutzer trifft Auswahl; leiht Medium aus, ruft es digital -->
    <!-- ab (Onleihe 3, filmfriend) oder nutzt es vor Ort -->
    <task name="Medium auswaehlen&#10;und nutzen" id="_Kunde_Task_K3_tp5" isForCompensation="false">
      <incoming>_Kunde_Flow_03_tp5</incoming>
      <outgoing>_Kunde_Flow_04_tp5</outgoing>
    </task>

    <!-- End Event: Medium wird genutzt -->
    <endEvent name="Medium wird&#10;genutzt" id="_Kunde_End_tp5">
      <incoming>_Kunde_Flow_04_tp5</incoming>
    </endEvent>

    <!-- Sequence Flows Kunde -->
    <sequenceFlow sourceRef="_Kunde_Start_tp5"    targetRef="_Kunde_Task_K1_tp5" id="_Kunde_Flow_01_tp5"/>
    <sequenceFlow sourceRef="_Kunde_Task_K1_tp5"  targetRef="_Kunde_Task_K2_tp5" id="_Kunde_Flow_02_tp5"/>
    <sequenceFlow sourceRef="_Kunde_Task_K2_tp5"  targetRef="_Kunde_Task_K3_tp5" id="_Kunde_Flow_03_tp5"/>
    <sequenceFlow sourceRef="_Kunde_Task_K3_tp5"  targetRef="_Kunde_End_tp5"     id="_Kunde_Flow_04_tp5"/>

  </process>

  <!-- =====================================================
       PROZESS: Organisation (Stadtbibliothek Stuttgart)
       Lanes: Auskunft/Information & Veranstaltungen | Digitale Dienste

       Ablauf:
         O-Start → O1 Vermittlungsangebote planen
                 → O2 Bestand praesentieren und auszeichnen
                 → O3 Veranstaltungen und Fuehrungen durchfuehren
                 → O4 Rechercheanfrage bearbeiten
                 → O5 Digitale Zugaenge vermitteln (Lane 2)
                 → O6 Medienempfehlung aussprechen (Lane 2)
                 → O-End
       ===================================================== -->
  <process name="Organisation"
           id="process_Org_tp5"
           isExecutable="false"
           isClosed="false"
           processType="None">

    <laneSet id="laneSet_Org_tp5">

      <!-- Lane 1: Auskunft/Information & Veranstaltungen (y=390, Hoehe=300) -->
      <lane name="Auskunft/Information &amp; Veranstaltungen" id="_Org_Lane_Auskunft_tp5">
        <flowNodeRef>_Org_Start_tp5</flowNodeRef>
        <flowNodeRef>_Org_Task_O1_tp5</flowNodeRef>
        <flowNodeRef>_Org_Task_O2_tp5</flowNodeRef>
        <flowNodeRef>_Org_Task_O3_tp5</flowNodeRef>
        <flowNodeRef>_Org_Task_O4_tp5</flowNodeRef>
      </lane>

      <!-- Lane 2: Digitale Dienste (y=690, Hoehe=300) -->
      <lane name="Digitale Dienste" id="_Org_Lane_Digital_tp5">
        <flowNodeRef>_Org_Task_O5_tp5</flowNodeRef>
        <flowNodeRef>_Org_Task_O6_tp5</flowNodeRef>
        <flowNodeRef>_Org_End_tp5</flowNodeRef>
      </lane>

    </laneSet>

    <!-- Message Start Event: Informationsbedarf eingegangen -->
    <startEvent name="Informationsbedarf&#10;eingegangen" id="_Org_Start_tp5">
      <outgoing>_Org_Flow_01_tp5</outgoing>
      <messageEventDefinition id="msgEvtDef_Org_Start_tp5"/>
    </startEvent>

    <!-- O1: Vermittlungsangebote planen (Auskunft/Information, Veranstaltungen) -->
    <!-- Zielgruppen- und themenspezifische Formate konzipieren; -->
    <!-- Themenwelten aktualisieren; Veranstaltungsprogramm planen; -->
    <!-- Grundlage: Bestandsprofil aus TP1 Umfeldanalyse -->
    <task name="Vermittlungsangebote&#10;planen" id="_Org_Task_O1_tp5" isForCompensation="false">
      <incoming>_Org_Flow_01_tp5</incoming>
      <outgoing>_Org_Flow_02_tp5</outgoing>
    </task>

    <!-- O2: Bestand praesentieren und auszeichnen (Auskunft/Information) -->
    <!-- Thematische Aufstellungen, Neuerwerbungsregale gestalten; -->
    <!-- Themenwelten im aDIS/WebOPAC pflegen; Medienpakete aufbereiten -->
    <task name="Bestand praesentieren&#10;und auszeichnen" id="_Org_Task_O2_tp5" isForCompensation="false">
      <incoming>_Org_Flow_02_tp5</incoming>
      <outgoing>_Org_Flow_03_tp5</outgoing>
    </task>

    <!-- O3: Veranstaltungen und Fuehrungen durchfuehren (Veranstaltungen) -->
    <!-- Lesungen, Vortraege, Workshops, Bibliotheksfuehrungen, Kinderprogramm, -->
    <!-- Kamishibai, Escape-Games; Kooperationen mit Schulen, VHS, Quartieren -->
    <task name="Veranstaltungen und&#10;Fuehrungen durchfuehren" id="_Org_Task_O3_tp5" isForCompensation="false">
      <incoming>_Org_Flow_03_tp5</incoming>
      <outgoing>_Org_Flow_04_tp5</outgoing>
    </task>

    <!-- O4: Rechercheanfrage bearbeiten (Auskunft/Information) -->
    <!-- Informationsbedarf entgegennehmen; Medien im aDIS/WebOPAC -->
    <!-- (inkl. KI-Chatbot) und Fachdatenbanken recherchieren; Ergebnis aufbereiten -->
    <task name="Rechercheanfrage&#10;bearbeiten" id="_Org_Task_O4_tp5" isForCompensation="false">
      <incoming>_Org_Flow_04_tp5</incoming>
      <outgoing>_Org_Flow_05_tp5</outgoing>
    </task>

    <!-- O5: Digitale Zugaenge vermitteln (Digitale Dienste) -->
    <!-- Einfuehrung in Onleihe 3, filmfriend, eBibliothek und Fachdatenbanken; -->
    <!-- Zugangsvoraussetzungen (Leserausweis) pruefen und unterstuetzen -->
    <task name="Digitale Zugaenge&#10;vermitteln" id="_Org_Task_O5_tp5" isForCompensation="false">
      <incoming>_Org_Flow_05_tp5</incoming>
      <outgoing>_Org_Flow_06_tp5</outgoing>
    </task>

    <!-- O6: Medienempfehlung aussprechen (Digitale Dienste / Auskunft) -->
    <!-- Konkrete bedarfsgerechte Empfehlung auf Basis der Recherche aussprechen; -->
    <!-- Medien bereitstellen oder im OPAC zeigen; Interaktion dokumentieren -->
    <task name="Medienempfehlung&#10;aussprechen" id="_Org_Task_O6_tp5" isForCompensation="false">
      <incoming>_Org_Flow_06_tp5</incoming>
      <outgoing>_Org_Flow_07_tp5</outgoing>
    </task>

    <!-- End Event: Medium wird genutzt -->
    <endEvent name="Medium wird&#10;genutzt" id="_Org_End_tp5">
      <incoming>_Org_Flow_07_tp5</incoming>
    </endEvent>

    <!-- Sequence Flows Organisation -->
    <sequenceFlow sourceRef="_Org_Start_tp5"     targetRef="_Org_Task_O1_tp5" id="_Org_Flow_01_tp5"/>
    <sequenceFlow sourceRef="_Org_Task_O1_tp5"   targetRef="_Org_Task_O2_tp5" id="_Org_Flow_02_tp5"/>
    <sequenceFlow sourceRef="_Org_Task_O2_tp5"   targetRef="_Org_Task_O3_tp5" id="_Org_Flow_03_tp5"/>
    <sequenceFlow sourceRef="_Org_Task_O3_tp5"   targetRef="_Org_Task_O4_tp5" id="_Org_Flow_04_tp5"/>
    <sequenceFlow sourceRef="_Org_Task_O4_tp5"   targetRef="_Org_Task_O5_tp5" id="_Org_Flow_05_tp5"/>
    <sequenceFlow sourceRef="_Org_Task_O5_tp5"   targetRef="_Org_Task_O6_tp5" id="_Org_Flow_06_tp5"/>
    <sequenceFlow sourceRef="_Org_Task_O6_tp5"   targetRef="_Org_End_tp5"     id="_Org_Flow_07_tp5"/>

  </process>

  <!-- =====================================================
       BPMN-DI: Diagramm-Visualisierung

       Koordinatensystem:
         Kunde:        y=0    – y=380    | Events y=172, Tasks y=152, Center y=190
         Organisation: y=390  – y=990
           Lane 1 Auskunft/Veranstaltungen: y=390 – y=690 | Tasks y=502, Center y=540
           Lane 2 Digitale Dienste:         y=690 – y=990 | Tasks y=802, Center y=840

       Task-Dimensionen:  151 x 76 px
       Event-Dimensionen:  36 x 36 px
       Horizontaler Abstand: 60 px

       X-Positionen:
         Kunde: Start=120, K1=220, K2=431, K3=642, End=853
         Lane 1: Start=120, O1=220, O2=431, O3=642, O4=853
         Lane 2: O5=853 (gleiche x-Achse wie O4), O6=1064, End=1275

       Sequence Flow O4→O5 (Lane1→Lane2): senkrecht nach unten (x=928)

       Message Flow 1 (K1→Org-Start, Waypoints 5px vor Pool-Grenze y=385):
         (295,228) → (295,385) → (138,385) → (138,522)
       Message Flow 2 (O6→K2, Waypoints 5px ueber Pool-Grenze y=395):
         (1139,802) → (1139,395) → (506,395) → (506,228)
       ===================================================== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_bib_tp5">
    <bpmndi:BPMNPlane bpmnElement="Collaboration_bib_tp5_medien_vermitteln">

      <!-- ===== POOL: Kunde (y=0..380) ===== -->
      <bpmndi:BPMNShape bpmnElement="_Kunde_Participant_tp5" isHorizontal="true">
        <omgdc:Bounds x="10" y="0" width="1840" height="380"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="_Kunde_Lane_tp5" isHorizontal="true">
        <omgdc:Bounds x="40" y="0" width="1810" height="380"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: Start Event (Informationsbedarf festgestellt) -->
      <bpmndi:BPMNShape bpmnElement="_Kunde_Start_tp5">
        <omgdc:Bounds x="120" y="172" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: K1 - Rechercheanfrage stellen -->
      <bpmndi:BPMNShape bpmnElement="_Kunde_Task_K1_tp5">
        <omgdc:Bounds x="220" y="152" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: K2 - Medienempfehlung entgegennehmen -->
      <bpmndi:BPMNShape bpmnElement="_Kunde_Task_K2_tp5">
        <omgdc:Bounds x="431" y="152" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: K3 - Medium auswaehlen und nutzen -->
      <bpmndi:BPMNShape bpmnElement="_Kunde_Task_K3_tp5">
        <omgdc:Bounds x="642" y="152" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: End Event (Medium wird genutzt) -->
      <bpmndi:BPMNShape bpmnElement="_Kunde_End_tp5">
        <omgdc:Bounds x="853" y="172" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: Sequence Flows -->
      <bpmndi:BPMNEdge bpmnElement="_Kunde_Flow_01_tp5">
        <omgdi:waypoint x="156" y="190"/>
        <omgdi:waypoint x="220" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_Kunde_Flow_02_tp5">
        <omgdi:waypoint x="371" y="190"/>
        <omgdi:waypoint x="431" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_Kunde_Flow_03_tp5">
        <omgdi:waypoint x="582" y="190"/>
        <omgdi:waypoint x="642" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_Kunde_Flow_04_tp5">
        <omgdi:waypoint x="793" y="190"/>
        <omgdi:waypoint x="853" y="190"/>
      </bpmndi:BPMNEdge>

      <!-- ===== POOL: Organisation (y=390..990) ===== -->
      <bpmndi:BPMNShape bpmnElement="_Org_Participant_tp5" isHorizontal="true">
        <omgdc:Bounds x="10" y="390" width="1840" height="600"/>
      </bpmndi:BPMNShape>

      <!-- Lane 1: Auskunft/Information & Veranstaltungen (y=390..690) -->
      <bpmndi:BPMNShape bpmnElement="_Org_Lane_Auskunft_tp5" isHorizontal="true">
        <omgdc:Bounds x="40" y="390" width="1810" height="300"/>
      </bpmndi:BPMNShape>

      <!-- Lane 2: Digitale Dienste (y=690..990) -->
      <bpmndi:BPMNShape bpmnElement="_Org_Lane_Digital_tp5" isHorizontal="true">
        <omgdc:Bounds x="40" y="690" width="1810" height="300"/>
      </bpmndi:BPMNShape>

      <!-- ===== Lane 1: Auskunft/Information & Veranstaltungen ===== -->

      <!-- Org: Message Start Event (Informationsbedarf eingegangen) -->
      <bpmndi:BPMNShape bpmnElement="_Org_Start_tp5">
        <omgdc:Bounds x="120" y="522" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Org: O1 - Vermittlungsangebote planen -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O1_tp5">
        <omgdc:Bounds x="220" y="502" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Org: O2 - Bestand praesentieren und auszeichnen -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O2_tp5">
        <omgdc:Bounds x="431" y="502" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Org: O3 - Veranstaltungen und Fuehrungen durchfuehren -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O3_tp5">
        <omgdc:Bounds x="642" y="502" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Org: O4 - Rechercheanfrage bearbeiten -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O4_tp5">
        <omgdc:Bounds x="853" y="502" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- ===== Lane 2: Digitale Dienste ===== -->

      <!-- Org: O5 - Digitale Zugaenge vermitteln -->
      <!-- Gleiche x-Achse wie O4 (x=853) fuer senkrechten Fluss O4→O5 -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O5_tp5">
        <omgdc:Bounds x="853" y="802" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Org: O6 - Medienempfehlung aussprechen -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O6_tp5">
        <omgdc:Bounds x="1064" y="802" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Org: End Event (Medium wird genutzt) -->
      <bpmndi:BPMNShape bpmnElement="_Org_End_tp5">
        <omgdc:Bounds x="1275" y="822" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- ===== Sequence Flows Organisation ===== -->

      <!-- O-Start → O1 (Lane 1) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_01_tp5">
        <omgdi:waypoint x="156" y="540"/>
        <omgdi:waypoint x="220" y="540"/>
      </bpmndi:BPMNEdge>

      <!-- O1 → O2 (Lane 1) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_02_tp5">
        <omgdi:waypoint x="371" y="540"/>
        <omgdi:waypoint x="431" y="540"/>
      </bpmndi:BPMNEdge>

      <!-- O2 → O3 (Lane 1) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_03_tp5">
        <omgdi:waypoint x="582" y="540"/>
        <omgdi:waypoint x="642" y="540"/>
      </bpmndi:BPMNEdge>

      <!-- O3 → O4 (Lane 1) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_04_tp5">
        <omgdi:waypoint x="793" y="540"/>
        <omgdi:waypoint x="853" y="540"/>
      </bpmndi:BPMNEdge>

      <!-- O4 → O5 (Lane 1 → Lane 2): senkrecht nach unten auf gleicher x-Achse x=928 -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_05_tp5">
        <omgdi:waypoint x="928" y="578"/>
        <omgdi:waypoint x="928" y="802"/>
      </bpmndi:BPMNEdge>

      <!-- O5 → O6 (Lane 2) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_06_tp5">
        <omgdi:waypoint x="1004" y="840"/>
        <omgdi:waypoint x="1064" y="840"/>
      </bpmndi:BPMNEdge>

      <!-- O6 → O-End (Lane 2) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_07_tp5">
        <omgdi:waypoint x="1215" y="840"/>
        <omgdi:waypoint x="1275" y="840"/>
      </bpmndi:BPMNEdge>

      <!-- ===== MESSAGE FLOWS ===== -->

      <!-- Message Flow 1: K1 → Org-Start -->
      <!-- Kunde stellt Rechercheanfrage; Org-Start empfaengt als Message Start -->
      <!-- Route: unten aus K1, 5px vor Pool-Grenze (y=385), links zu Org-Start, runter -->
      <bpmndi:BPMNEdge bpmnElement="_MF_K_to_Org_tp5">
        <omgdi:waypoint x="295" y="228"/>
        <omgdi:waypoint x="295" y="385"/>
        <omgdi:waypoint x="138" y="385"/>
        <omgdi:waypoint x="138" y="522"/>
      </bpmndi:BPMNEdge>

      <!-- Message Flow 2: O6 → K2 -->
      <!-- Org spricht Medienempfehlung aus; Kunde empfaengt in K2 -->
      <!-- Route: oben aus O6, 5px ueber Pool-Grenze (y=395), links zu K2, hoch -->
      <bpmndi:BPMNEdge bpmnElement="_MF_Org_to_K_tp5">
        <omgdi:waypoint x="1139" y="802"/>
        <omgdi:waypoint x="1139" y="395"/>
        <omgdi:waypoint x="506" y="395"/>
        <omgdi:waypoint x="506" y="228"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
