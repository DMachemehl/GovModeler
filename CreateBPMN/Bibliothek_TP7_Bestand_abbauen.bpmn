<?xml version="1.0" encoding="utf-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:adonis="http://www.boc-group.com"
             xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             id="definition_bib_tp7_bestand_abbauen"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL http://www.omg.org/spec/BPMN/2.0/20100501/BPMN20.xsd"
             targetNamespace="http://www.boc-group.com">

  <!-- =====================================================
       COLLABORATION: TP7 Bestand abbauen
       Uebergeordneter Prozess: Medien managen
       Stadtbibliothek Stuttgart

       Struktur: 2-Pool-Kollaboration (Kunde | Organisation)
         Kunde:        y=0,   Hoehe=380  | Tasks y=152, Events y=172, Center y=190
         Organisation: y=390, Hoehe=600  | 2 Lanes (je 300px)
           Lane 1 Lektoratsteam:          y=390, Center y=540
           Lane 2 Ausleihe/Katalogis.:    y=690, Center y=840

       Supplier: TP1 Umfeldanalyse → Bestandsprofil als Ausscheidungsmassstab
                 TP6 Bestand pflegen → Zustandshinweise schadhafter Medien
       Happy Path: Ausscheidungsbedarf festgestellt → Medium ist ausgeschieden

       Message Flows (bidirektional):
         O6 → K1: Medienflohmarkt-Ankuendigung (Org → Kunde)
         K2 → O7: Ausgesondertes Medium (Kunde → Org)

       Sequence Flow O3→O4 (Lane1→Lane2): senkrecht nach unten (gleiche x-Achse x=717)
       ===================================================== -->
  <collaboration id="Collaboration_bib_tp7_bestand_abbauen"
                 name="TP7 Bestand abbauen | Medien managen"
                 isClosed="false">

    <participant processRef="process_Kunde_tp7"
                 name="Kunde"
                 id="_Kunde_Participant_tp7"/>
    <participant processRef="process_Org_tp7"
                 name="Organisation"
                 id="_Org_Participant_tp7"/>

    <!-- Message Flow 1: Organisation → Kunde -->
    <!-- Ausleihe kuendigt Medienflohmarkt an; Buerger erhaelt Einladung -->
    <messageFlow id="_MF_O6_to_K1_tp7"
                 name="Medienflohmarkt-Ankuendigung"
                 sourceRef="_Org_Task_O6_tp7"
                 targetRef="_Kunde_Task_K1_tp7"/>

    <!-- Message Flow 2: Kunde → Organisation -->
    <!-- Bibliotheksnutzer erwirbt ausgesondertes Medium beim Flohmarkt -->
    <messageFlow id="_MF_K2_to_O7_tp7"
                 name="Ausgesondertes Medium"
                 sourceRef="_Kunde_Task_K2_tp7"
                 targetRef="_Org_Task_O7_tp7"/>

  </collaboration>

  <!-- =====================================================
       PROZESS: Kunde (Bibliotheksnutzer/-in)
       e2e-Rahmen: Ausscheidungsbedarf festgestellt → Ausgesondertes Medium erhalten
       ===================================================== -->
  <process name="Kunde"
           id="process_Kunde_tp7"
           isExecutable="false"
           isClosed="false"
           processType="None">

    <laneSet id="laneSet_Kunde_tp7">
      <lane name="Bibliotheksnutzer/-in" id="_Kunde_Lane_tp7">
        <flowNodeRef>_Kunde_Start_tp7</flowNodeRef>
        <flowNodeRef>_Kunde_Task_K1_tp7</flowNodeRef>
        <flowNodeRef>_Kunde_Task_K2_tp7</flowNodeRef>
        <flowNodeRef>_Kunde_End_tp7</flowNodeRef>
      </lane>
    </laneSet>

    <!-- Start Event: Ausscheidungsbedarf festgestellt -->
    <startEvent name="Ausscheidungsbedarf&#10;festgestellt" id="_Kunde_Start_tp7">
      <outgoing>_Kunde_Flow_01_tp7</outgoing>
    </startEvent>

    <!-- K1: Medienflohmarkt-Ankuendigung erhalten -->
    <!-- Bibliotheksnutzer erhaelt Hinweis auf verfuegbare ausgesonderte Medien -->
    <!-- per Aushang, Website, Social Media oder Newsletter -->
    <task name="Medienflohmarkt-&#10;Ankuendigung erhalten" id="_Kunde_Task_K1_tp7" isForCompensation="false">
      <incoming>_Kunde_Flow_01_tp7</incoming>
      <outgoing>_Kunde_Flow_02_tp7</outgoing>
    </task>

    <!-- K2: Ausgesondertes Medium erwerben -->
    <!-- Bibliotheksnutzer nimmt gewuenschtes Medium beim Medienflohmarkt -->
    <!-- oder an der Abgabestelle gegen geringes Entgelt oder kostenlos entgegen -->
    <task name="Ausgesondertes Medium&#10;erwerben" id="_Kunde_Task_K2_tp7" isForCompensation="false">
      <incoming>_Kunde_Flow_02_tp7</incoming>
      <outgoing>_Kunde_Flow_03_tp7</outgoing>
    </task>

    <!-- End Event: Ausgesondertes Medium erhalten -->
    <endEvent name="Ausgesondertes Medium&#10;erhalten" id="_Kunde_End_tp7">
      <incoming>_Kunde_Flow_03_tp7</incoming>
    </endEvent>

    <!-- Sequence Flows Kunde -->
    <sequenceFlow sourceRef="_Kunde_Start_tp7"    targetRef="_Kunde_Task_K1_tp7" id="_Kunde_Flow_01_tp7"/>
    <sequenceFlow sourceRef="_Kunde_Task_K1_tp7"  targetRef="_Kunde_Task_K2_tp7" id="_Kunde_Flow_02_tp7"/>
    <sequenceFlow sourceRef="_Kunde_Task_K2_tp7"  targetRef="_Kunde_End_tp7"     id="_Kunde_Flow_03_tp7"/>

  </process>

  <!-- =====================================================
       PROZESS: Organisation (Stadtbibliothek Stuttgart)
       Lanes: Lektoratsteam | Ausleihe / Katalogisierung

       Ablauf:
         O-Start → O1 Ausscheidungskandidaten identifizieren
                 → O2 Ausscheidungskandidaten bewerten
                 → O3 Ausscheidungsentscheidung treffen
                 → O4 Medium aus aDIS/BMS ausbuchen
                 → O5 Ausgesonderte Medien aufbereiten
                 → O6 Medienflohmarkt ankuendigen
                 → O7 Medium weitergeben oder entsorgen
                 → O-End
       ===================================================== -->
  <process name="Organisation"
           id="process_Org_tp7"
           isExecutable="false"
           isClosed="false"
           processType="None">

    <laneSet id="laneSet_Org_tp7">

      <!-- Lane 1: Lektoratsteam (y=390, Hoehe=300) -->
      <lane name="Lektoratsteam" id="_Org_Lane_Lektorat_tp7">
        <flowNodeRef>_Org_Start_tp7</flowNodeRef>
        <flowNodeRef>_Org_Task_O1_tp7</flowNodeRef>
        <flowNodeRef>_Org_Task_O2_tp7</flowNodeRef>
        <flowNodeRef>_Org_Task_O3_tp7</flowNodeRef>
      </lane>

      <!-- Lane 2: Ausleihe / Katalogisierung (y=690, Hoehe=300) -->
      <lane name="Ausleihe / Katalogisierung" id="_Org_Lane_Ausleihe_tp7">
        <flowNodeRef>_Org_Task_O4_tp7</flowNodeRef>
        <flowNodeRef>_Org_Task_O5_tp7</flowNodeRef>
        <flowNodeRef>_Org_Task_O6_tp7</flowNodeRef>
        <flowNodeRef>_Org_Task_O7_tp7</flowNodeRef>
        <flowNodeRef>_Org_End_tp7</flowNodeRef>
      </lane>

    </laneSet>

    <!-- Start Event: Ausscheidungsbedarf festgestellt -->
    <!-- Interner Ausloser: Bestandsprofil aus TP1 oder Zustandshinweis aus TP6 -->
    <startEvent name="Ausscheidungsbedarf&#10;festgestellt" id="_Org_Start_tp7">
      <outgoing>_Org_Flow_01_tp7</outgoing>
    </startEvent>

    <!-- O1: Ausscheidungskandidaten identifizieren (Lektoratsteam) -->
    <!-- Bestand anhand des Bestandsprofils sichten; Kandidaten nach Ausleihhaeufigkeit, -->
    <!-- Alter, Aktualitaet, physischem Zustand und Doubletten ermitteln -->
    <task name="Ausscheidungskandidaten&#10;identifizieren" id="_Org_Task_O1_tp7" isForCompensation="false">
      <incoming>_Org_Flow_01_tp7</incoming>
      <outgoing>_Org_Flow_02_tp7</outgoing>
    </task>

    <!-- O2: Ausscheidungskandidaten bewerten (Lektoratsteam) -->
    <!-- Kandidaten anhand bibliothekarischer Aussonderungskriterien bewerten; -->
    <!-- Bewertungsergebnis je Titel dokumentieren -->
    <task name="Ausscheidungskandidaten&#10;bewerten" id="_Org_Task_O2_tp7" isForCompensation="false">
      <incoming>_Org_Flow_02_tp7</incoming>
      <outgoing>_Org_Flow_03_tp7</outgoing>
    </task>

    <!-- O3: Ausscheidungsentscheidung treffen (Lektoratsteam) -->
    <!-- Fachlich begruendete Entscheidung ueber Ausscheidung, Reparatur -->
    <!-- oder Weiternutzung; Ausscheidungsliste finalisieren; -->
    <!-- Weiterverwendungsweg festlegen: Flohmarkt, Spende, Entsorgung -->
    <task name="Ausscheidungsentscheidung&#10;treffen" id="_Org_Task_O3_tp7" isForCompensation="false">
      <incoming>_Org_Flow_03_tp7</incoming>
      <outgoing>_Org_Flow_04_tp7</outgoing>
    </task>

    <!-- O4: Medium aus aDIS/BMS ausbuchen (Katalogisierung, Ausleihe) -->
    <!-- Exemplardatensatz auf "ausgeschieden" setzen; Titeldatensatz bei -->
    <!-- letztem Exemplar loeschen oder sperren; Bestandsstatistik aktualisieren -->
    <task name="Medium aus&#10;aDIS/BMS ausbuchen" id="_Org_Task_O4_tp7" isForCompensation="false">
      <incoming>_Org_Flow_04_tp7</incoming>
      <outgoing>_Org_Flow_05_tp7</outgoing>
    </task>

    <!-- O5: Ausgesonderte Medien aufbereiten (Ausleihe) -->
    <!-- Physische Medien aus dem Regal entnehmen und nach Weiterverwendungsweg -->
    <!-- sortieren: Flohmarkt, Buchspende, Entsorgung; Flohmarkt-Exemplare auszeichnen -->
    <task name="Ausgesonderte Medien&#10;aufbereiten" id="_Org_Task_O5_tp7" isForCompensation="false">
      <incoming>_Org_Flow_05_tp7</incoming>
      <outgoing>_Org_Flow_06_tp7</outgoing>
    </task>

    <!-- O6: Medienflohmarkt ankuendigen (Ausleihe) -->
    <!-- Oeffentliche Ankuendigung vorbereiten und veroeffentlichen; -->
    <!-- Aushang, Website, Newsletter, Social Media; Verkaufsbedingungen kommunizieren -->
    <task name="Medienflohmarkt&#10;ankuendigen" id="_Org_Task_O6_tp7" isForCompensation="false">
      <incoming>_Org_Flow_06_tp7</incoming>
      <outgoing>_Org_Flow_07_tp7</outgoing>
    </task>

    <!-- O7: Medium weitergeben oder entsorgen (Ausleihe) -->
    <!-- Ausgesonderte Medien im Rahmen des Medienflohmarkts abgeben, -->
    <!-- als Buchspende an soziale Einrichtungen oder zur Entsorgung weiterleiten; -->
    <!-- Flohmarkt-Erloese verbuchen -->
    <task name="Medium weitergeben&#10;oder entsorgen" id="_Org_Task_O7_tp7" isForCompensation="false">
      <incoming>_Org_Flow_07_tp7</incoming>
      <outgoing>_Org_Flow_08_tp7</outgoing>
    </task>

    <!-- End Event: Medium ist ausgeschieden -->
    <endEvent name="Medium ist&#10;ausgeschieden" id="_Org_End_tp7">
      <incoming>_Org_Flow_08_tp7</incoming>
    </endEvent>

    <!-- Sequence Flows Organisation -->
    <sequenceFlow sourceRef="_Org_Start_tp7"     targetRef="_Org_Task_O1_tp7" id="_Org_Flow_01_tp7"/>
    <sequenceFlow sourceRef="_Org_Task_O1_tp7"   targetRef="_Org_Task_O2_tp7" id="_Org_Flow_02_tp7"/>
    <sequenceFlow sourceRef="_Org_Task_O2_tp7"   targetRef="_Org_Task_O3_tp7" id="_Org_Flow_03_tp7"/>
    <sequenceFlow sourceRef="_Org_Task_O3_tp7"   targetRef="_Org_Task_O4_tp7" id="_Org_Flow_04_tp7"/>
    <sequenceFlow sourceRef="_Org_Task_O4_tp7"   targetRef="_Org_Task_O5_tp7" id="_Org_Flow_05_tp7"/>
    <sequenceFlow sourceRef="_Org_Task_O5_tp7"   targetRef="_Org_Task_O6_tp7" id="_Org_Flow_06_tp7"/>
    <sequenceFlow sourceRef="_Org_Task_O6_tp7"   targetRef="_Org_Task_O7_tp7" id="_Org_Flow_07_tp7"/>
    <sequenceFlow sourceRef="_Org_Task_O7_tp7"   targetRef="_Org_End_tp7"     id="_Org_Flow_08_tp7"/>

  </process>

  <!-- =====================================================
       BPMN-DI: Diagramm-Visualisierung

       Koordinatensystem:
         Kunde:        y=0    – y=380    | Events y=172, Tasks y=152, Center y=190
         Organisation: y=390  – y=990
           Lane 1 Lektoratsteam:        y=390 – y=690 | Tasks y=502, Center y=540
           Lane 2 Ausleihe/Katalogis.:  y=690 – y=990 | Tasks y=802, Center y=840

       Task-Dimensionen:  151 x 76 px
       Event-Dimensionen:  36 x 36 px
       Horizontaler Abstand: 60 px

       X-Positionen:
         Kunde:  Start=120, K1=220, K2=431, End=642
         Lane 1: Start=120, O1=220, O2=431, O3=642
         Lane 2: O4=642 (gleiche x-Achse wie O3), O5=853, O6=1064, O7=1275, End=1486

       Sequence Flow O3→O4 (Lane1→Lane2): senkrecht nach unten (x-Achse x=717)

       Message Flow 1 O6→K1 (5px ueber Pool-Grenze y=395):
         (1139,802) → (1139,395) → (295,395) → (295,228)
       Message Flow 2 K2→O7 (5px vor Pool-Grenze y=385):
         (506,228) → (506,385) → (1350,385) → (1350,802)
       ===================================================== -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_bib_tp7">
    <bpmndi:BPMNPlane bpmnElement="Collaboration_bib_tp7_bestand_abbauen">

      <!-- ===== POOL: Kunde (y=0..380) ===== -->
      <bpmndi:BPMNShape bpmnElement="_Kunde_Participant_tp7" isHorizontal="true">
        <omgdc:Bounds x="10" y="0" width="1840" height="380"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape bpmnElement="_Kunde_Lane_tp7" isHorizontal="true">
        <omgdc:Bounds x="40" y="0" width="1810" height="380"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: Start Event (Ausscheidungsbedarf festgestellt) -->
      <bpmndi:BPMNShape bpmnElement="_Kunde_Start_tp7">
        <omgdc:Bounds x="120" y="172" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: K1 - Medienflohmarkt-Ankuendigung erhalten -->
      <bpmndi:BPMNShape bpmnElement="_Kunde_Task_K1_tp7">
        <omgdc:Bounds x="220" y="152" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: K2 - Ausgesondertes Medium erwerben -->
      <bpmndi:BPMNShape bpmnElement="_Kunde_Task_K2_tp7">
        <omgdc:Bounds x="431" y="152" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: End Event (Ausgesondertes Medium erhalten) -->
      <bpmndi:BPMNShape bpmnElement="_Kunde_End_tp7">
        <omgdc:Bounds x="642" y="172" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Kunde: Sequence Flows -->
      <bpmndi:BPMNEdge bpmnElement="_Kunde_Flow_01_tp7">
        <omgdi:waypoint x="156" y="190"/>
        <omgdi:waypoint x="220" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_Kunde_Flow_02_tp7">
        <omgdi:waypoint x="371" y="190"/>
        <omgdi:waypoint x="431" y="190"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge bpmnElement="_Kunde_Flow_03_tp7">
        <omgdi:waypoint x="582" y="190"/>
        <omgdi:waypoint x="642" y="190"/>
      </bpmndi:BPMNEdge>

      <!-- ===== POOL: Organisation (y=390..990) ===== -->
      <bpmndi:BPMNShape bpmnElement="_Org_Participant_tp7" isHorizontal="true">
        <omgdc:Bounds x="10" y="390" width="1840" height="600"/>
      </bpmndi:BPMNShape>

      <!-- Lane 1: Lektoratsteam (y=390..690) -->
      <bpmndi:BPMNShape bpmnElement="_Org_Lane_Lektorat_tp7" isHorizontal="true">
        <omgdc:Bounds x="40" y="390" width="1810" height="300"/>
      </bpmndi:BPMNShape>

      <!-- Lane 2: Ausleihe / Katalogisierung (y=690..990) -->
      <bpmndi:BPMNShape bpmnElement="_Org_Lane_Ausleihe_tp7" isHorizontal="true">
        <omgdc:Bounds x="40" y="690" width="1810" height="300"/>
      </bpmndi:BPMNShape>

      <!-- ===== Lane 1: Lektoratsteam ===== -->

      <!-- Org: Start Event (Ausscheidungsbedarf festgestellt) -->
      <bpmndi:BPMNShape bpmnElement="_Org_Start_tp7">
        <omgdc:Bounds x="120" y="522" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- Org: O1 - Ausscheidungskandidaten identifizieren -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O1_tp7">
        <omgdc:Bounds x="220" y="502" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Org: O2 - Ausscheidungskandidaten bewerten -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O2_tp7">
        <omgdc:Bounds x="431" y="502" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Org: O3 - Ausscheidungsentscheidung treffen -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O3_tp7">
        <omgdc:Bounds x="642" y="502" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- ===== Lane 2: Ausleihe / Katalogisierung ===== -->

      <!-- Org: O4 - Medium aus aDIS/BMS ausbuchen -->
      <!-- Gleiche x-Achse wie O3 (x=642) fuer senkrechten Fluss O3→O4 -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O4_tp7">
        <omgdc:Bounds x="642" y="802" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Org: O5 - Ausgesonderte Medien aufbereiten -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O5_tp7">
        <omgdc:Bounds x="853" y="802" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Org: O6 - Medienflohmarkt ankuendigen -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O6_tp7">
        <omgdc:Bounds x="1064" y="802" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Org: O7 - Medium weitergeben oder entsorgen -->
      <bpmndi:BPMNShape bpmnElement="_Org_Task_O7_tp7">
        <omgdc:Bounds x="1275" y="802" width="151" height="76"/>
      </bpmndi:BPMNShape>

      <!-- Org: End Event (Medium ist ausgeschieden) -->
      <bpmndi:BPMNShape bpmnElement="_Org_End_tp7">
        <omgdc:Bounds x="1486" y="822" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <!-- ===== Sequence Flows Organisation ===== -->

      <!-- O-Start → O1 (Lane 1) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_01_tp7">
        <omgdi:waypoint x="156" y="540"/>
        <omgdi:waypoint x="220" y="540"/>
      </bpmndi:BPMNEdge>

      <!-- O1 → O2 (Lane 1) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_02_tp7">
        <omgdi:waypoint x="371" y="540"/>
        <omgdi:waypoint x="431" y="540"/>
      </bpmndi:BPMNEdge>

      <!-- O2 → O3 (Lane 1) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_03_tp7">
        <omgdi:waypoint x="582" y="540"/>
        <omgdi:waypoint x="642" y="540"/>
      </bpmndi:BPMNEdge>

      <!-- O3 → O4 (Lane 1 → Lane 2): senkrecht nach unten auf gleicher x-Achse x=717 -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_04_tp7">
        <omgdi:waypoint x="717" y="578"/>
        <omgdi:waypoint x="717" y="802"/>
      </bpmndi:BPMNEdge>

      <!-- O4 → O5 (Lane 2) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_05_tp7">
        <omgdi:waypoint x="793" y="840"/>
        <omgdi:waypoint x="853" y="840"/>
      </bpmndi:BPMNEdge>

      <!-- O5 → O6 (Lane 2) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_06_tp7">
        <omgdi:waypoint x="1004" y="840"/>
        <omgdi:waypoint x="1064" y="840"/>
      </bpmndi:BPMNEdge>

      <!-- O6 → O7 (Lane 2) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_07_tp7">
        <omgdi:waypoint x="1215" y="840"/>
        <omgdi:waypoint x="1275" y="840"/>
      </bpmndi:BPMNEdge>

      <!-- O7 → O-End (Lane 2) -->
      <bpmndi:BPMNEdge bpmnElement="_Org_Flow_08_tp7">
        <omgdi:waypoint x="1426" y="840"/>
        <omgdi:waypoint x="1486" y="840"/>
      </bpmndi:BPMNEdge>

      <!-- ===== MESSAGE FLOWS ===== -->

      <!-- Message Flow 1: O6 → K1 (Medienflohmarkt-Ankuendigung) -->
      <!-- Ausleihe kuendigt Flohmarkt an; Kunde erhaelt Einladung -->
      <!-- Route: oben aus O6, 5px ueber Pool-Grenze (y=395), links zu K1, hoch -->
      <bpmndi:BPMNEdge bpmnElement="_MF_O6_to_K1_tp7">
        <omgdi:waypoint x="1139" y="802"/>
        <omgdi:waypoint x="1139" y="395"/>
        <omgdi:waypoint x="295" y="395"/>
        <omgdi:waypoint x="295" y="228"/>
      </bpmndi:BPMNEdge>

      <!-- Message Flow 2: K2 → O7 (Ausgesondertes Medium) -->
      <!-- Bibliotheksnutzer erwirbt Medium beim Flohmarkt; Ausleihe gibt ab -->
      <!-- Route: unten aus K2, 5px vor Pool-Grenze (y=385), rechts zu O7, runter -->
      <bpmndi:BPMNEdge bpmnElement="_MF_K2_to_O7_tp7">
        <omgdi:waypoint x="506" y="228"/>
        <omgdi:waypoint x="506" y="385"/>
        <omgdi:waypoint x="1350" y="385"/>
        <omgdi:waypoint x="1350" y="802"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>
